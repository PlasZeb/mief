---
---
<nav class="sticky top-0 z-50 w-full border-b border-white/10 bg-slate-900/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <div class="flex items-center gap-3 shrink-0">
      <img src="/assets/logo.jpg" alt="MIEF Logo" class="h-10 w-10 rounded-lg object-cover shadow-lg shadow-cyan-500/20" />
      <span class="text-xl font-bold tracking-tight text-white">MIEF</span>
    </div>
    
    {/* Desktop Menu - Hidden on tablets and below to prevent overlapping */}
    <div class="hidden 2xl:flex items-center gap-6 text-sm font-medium text-slate-300">
      <ul class="flex gap-6">
        <li><a href="#miert" class="transition hover:text-cyan-400">Kik vagyunk</a></li>
        <li><a href="#kinek" class="transition hover:text-cyan-400">Miért fontos az MI-etika?</a></li>
        <li><a href="#hirek" class="transition hover:text-cyan-400 font-semibold text-cyan-300">Tudástár</a></li>
        <li><a href="#esemenyek" class="transition hover:text-cyan-400">Eseménytár</a></li>
        <li><a href="#programok" class="transition hover:text-cyan-400">Műhelyek és programok</a></li>
        <li><a href="#fokusz" class="transition hover:text-cyan-400">Szakértői területeink</a></li>
        <li><a href="#kapcsolat" class="transition hover:text-cyan-400">Kapcsolat</a></li>
      </ul>
    </div>

    {/* Right side actions - Always visible */}
    <div class="flex items-center gap-3 sm:gap-6">
      <div class="hidden sm:flex items-center gap-4">
        <a href="#international" class="text-xs font-bold text-slate-400 hover:text-white transition uppercase tracking-widest">English</a>
        <a href="https://www.linkedin.com/company/113130027" target="_blank" class="text-slate-400 hover:text-cyan-400 transition" title="MIEF LinkedIn">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
      </div>

      <a href="#regisztracio" class="rounded-full bg-cyan-400 px-4 sm:px-5 py-2 text-xs sm:text-sm font-semibold text-slate-900 transition hover:bg-cyan-300 whitespace-nowrap">
        Csatlakozás
      </a>

      {/* Hamburger Toggle */}
      <button id="menu-toggle" class="2xl:hidden flex flex-col gap-1.5 p-2 text-slate-300 hover:text-white transition" aria-label="Menu">
        <span class="h-0.5 w-6 bg-current transition-all duration-300"></span>
        <span class="h-0.5 w-6 bg-current transition-all duration-300"></span>
        <span class="h-0.5 w-6 bg-current transition-all duration-300"></span>
      </button>
    </div>
  </div>

  {/* Mobile Menu Overlay */}
  <div id="mobile-menu" class="fixed inset-0 z-40 hidden 2xl:hidden">
    <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-md" id="menu-backdrop"></div>
    <div class="absolute right-0 top-0 h-full w-72 bg-slate-900 border-l border-white/10 p-8 shadow-2xl transition-transform duration-300 translate-x-full overflow-y-auto" id="menu-content">
      <div class="flex justify-end mb-8">
        <button id="menu-close" class="text-slate-400 hover:text-white p-2">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <ul class="flex flex-col gap-6 text-lg font-medium text-slate-300">
        <li><a href="#miert" class="mobile-link transition hover:text-cyan-400">Kik vagyunk</a></li>
        <li><a href="#kinek" class="mobile-link transition hover:text-cyan-400">Miért fontos az MI-etika?</a></li>
        <li><a href="#hirek" class="mobile-link transition hover:text-cyan-400">Tudástár</a></li>
        <li><a href="#esemenyek" class="mobile-link transition hover:text-cyan-400">Eseménytár</a></li>
        <li><a href="#programok" class="mobile-link transition hover:text-cyan-400">Műhelyek és programok</a></li>
        <li><a href="#fokusz" class="mobile-link transition hover:text-cyan-400">Szakértői területeink</a></li>
        <li><a href="#kapcsolat" class="mobile-link transition hover:text-cyan-400">Kapcsolat</a></li>
      </ul>
      <div class="mt-12 pt-8 border-t border-white/5 flex flex-col gap-6">
        <a href="#international" class="mobile-link text-sm font-bold text-slate-400 uppercase tracking-widest">English Summary</a>
        <a href="https://www.linkedin.com/company/113130027" target="_blank" class="flex items-center gap-3 text-slate-400 hover:text-cyan-400 transition">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');
  const content = document.getElementById('menu-content');
  const backdrop = document.getElementById('menu-backdrop');
  const links = document.querySelectorAll('.mobile-link');

  function openMenu() {
    menu?.classList.remove('hidden');
    setTimeout(() => {
      content?.classList.remove('translate-x-full');
    }, 10);
  }

  function closeMenu() {
    content?.classList.add('translate-x-full');
    setTimeout(() => {
      menu?.classList.add('hidden');
    }, 300);
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  
  links.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
