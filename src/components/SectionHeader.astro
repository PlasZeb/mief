---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
}

const { eyebrow, title, description, center = false } = Astro.props;
---

<header class:list={["max-w-3xl", center ? "mx-auto text-center" : ""]}>
  {eyebrow && <p class="section-kicker">{eyebrow}</p>}
  <h2 class="section-heading">{title}</h2>
  {description && <p class="section-intro">{description}</p>}
</header>
