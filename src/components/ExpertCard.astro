---
interface Props {
  name: string;
  role: string;
  linkedinUrl?: string | null;
  imageUrl?: string | null;
  founder?: boolean;
  topics?: string[];
}

const { name, role, linkedinUrl, imageUrl, founder = false, topics = [] } = Astro.props;

const normalizedImageUrl = (() => {
  const url = imageUrl?.trim();
  if (!url) return null;
  if (/^(https?:|data:|\/)/i.test(url)) return url;
  return `/${url}`;
})();
---

<article class:list={["panel group p-6 sm:p-7", founder ? "border-cyan-200 bg-cyan-50/70" : ""]}>
  <div class="flex items-start gap-4">
    {normalizedImageUrl ? (
      <img src={normalizedImageUrl} alt={name} class="h-16 w-16 shrink-0 rounded-2xl object-cover ring-1 ring-slate-200" />
    ) : (
      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-slate-100 text-slate-400 ring-1 ring-slate-200">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
        </svg>
      </div>
    )}

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <h3 class="text-xl font-semibold tracking-tight text-slate-950 group-hover:text-cyan-700">{name}</h3>
        {founder && <span class="rounded-full border border-cyan-200 bg-cyan-50 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.24em] text-cyan-700">Alapító</span>}
      </div>
      <p class="mt-2 text-sm leading-7 text-slate-600">{role}</p>
    </div>
  </div>

  {topics.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {topics.map((topic) => (
        <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
          {topic}
        </span>
      ))}
    </div>
  )}

  {linkedinUrl && (
    <a href={linkedinUrl} target="_blank" rel="noreferrer" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-cyan-700 hover:text-cyan-600">
      LinkedIn profil
      <span aria-hidden="true">↗</span>
    </a>
  )}
</article>
