---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;

const iconSvgByKey: Record<string, string> = {
  shield:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v6c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6l7-3z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.5 12.5l1.7 1.7 3.3-3.7"/></svg>',
  scales:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 8l-3 5h6l-3-5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l-3 5h6l-3-5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 20h6"/></svg>',
  graduation:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-4 9 4-9 4-9-4z"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V15c0 1.7 2.2 3 5 3s5-1.3 5-3v-3.5"/></svg>',
  building:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 21V7l7-3 7 3v14"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 10h.01M12 10h.01M15 10h.01M9 14h.01M12 14h.01M15 14h.01"/></svg>',
  government:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 10v8M9 10v8M13 10v8M17 10v8"/><path stroke-linecap="round" stroke-linejoin="round" d="M4 18h16"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 4l8 4H4l8-4z"/></svg>',
  megaphone:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12v-2a1 1 0 011-1h2l8-4v14l-8-4H5a1 1 0 01-1-1v-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M18 10.5a3.5 3.5 0 010 3"/><path stroke-linecap="round" stroke-linejoin="round" d="M20 9a6 6 0 010 6"/></svg>',
  sword:
    '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14 4l6 6-8.5 8.5-2.5.5.5-2.5L18 8"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 16l-1.5 1.5M6.5 19l-2 2"/></svg>',
};

const iconSvg = icon ? iconSvgByKey[icon] : undefined;
---
<div class="group relative rounded-2xl border border-slate-200 bg-white p-8 shadow-[0_18px_42px_-30px_rgba(15,23,42,0.18)] transition hover:-translate-y-0.5 hover:border-cyan-200 hover:shadow-[0_24px_60px_-30px_rgba(15,23,42,0.22)]">
  <div class="relative">
    {iconSvg && (
      <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl border border-cyan-100 bg-cyan-50 text-cyan-700">
        <Fragment set:html={iconSvg} />
      </div>
    )}
    <h3 class="text-xl font-semibold tracking-tight text-slate-950 transition group-hover:text-cyan-700">{title}</h3>
    <p class="mt-4 leading-7 text-slate-600 transition">
      {description}
    </p>
  </div>
</div>
