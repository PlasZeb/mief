---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---
<div class="group relative rounded-2xl border border-white/10 bg-slate-900/70 p-8 transition hover:bg-slate-900 hover:border-cyan-400/30">
  <div class="relative">
    {icon && (
      <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg border border-cyan-400/20 bg-cyan-400/10 text-cyan-300">
        <span class="text-xl">{icon}</span>
      </div>
    )}
    <h3 class="text-xl font-bold text-white transition group-hover:text-cyan-300">{title}</h3>
    <p class="mt-4 leading-7 text-slate-300 transition group-hover:text-slate-200">
      {description}
    </p>
  </div>
</div>
