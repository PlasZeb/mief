---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---
<div class="group relative rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition hover:bg-white/[0.05] hover:border-cyan-400/30">
  <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-cyan-400/20 to-transparent opacity-0 transition group-hover:opacity-100"></div>
  
  <div class="relative">
    {icon && (
      <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
        <span class="text-xl">{icon}</span>
      </div>
    )}
    <h3 class="text-xl font-bold text-white transition group-hover:text-cyan-400">{title}</h3>
    <p class="mt-4 leading-7 text-slate-400 transition group-hover:text-slate-300">
      {description}
    </p>
  </div>
</div>
