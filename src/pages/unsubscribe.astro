---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
let success = "";
let error = "";

if (Astro.request.method === "POST" && db) {
  const data = await Astro.request.formData();
  const email = data.get("email");
  if (email) {
    try {
      const result = await db.prepare("DELETE FROM subscribers WHERE email = ?").bind(email).run();
      if (result.meta.changes > 0) {
        success = "Sikeresen leiratkoztál a hírlevelünkről.";
      } else {
        error = "Ez az email cím nem szerepel a listánkban.";
      }
    } catch (e) {
      error = "Hiba történt a leiratkozás során. Kérjük, próbáld újra később.";
    }
  } else {
    error = "Kérjük, add meg az email címedet.";
  }
}
---

<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leiratkozás | MIEF</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased">
    <Navbar />
    <main class="py-24 px-6">
      <div class="max-w-xl mx-auto text-center">
        <h1 class="text-3xl font-bold text-white mb-6">Leiratkozás</h1>
        <div class="bg-slate-800 border border-white/10 rounded-3xl p-8 shadow-xl">
          {success ? (
            <div class="py-4">
              <p class="text-emerald-400 font-medium mb-6">{success}</p>
              <a href="/" class="inline-block bg-slate-700 hover:bg-slate-600 text-white px-6 py-2 rounded-xl transition">Vissza a főoldalra</a>
            </div>
          ) : (
            <form method="POST" class="flex flex-col gap-4">
              <p class="text-slate-400 text-sm mb-4">Add meg az email címedet a leiratkozáshoz.</p>
              {error && <p class="p-3 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm">{error}</p>}
              <input
                type="email"
                name="email"
                required
                placeholder="email@pelda.hu"
                class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-cyan-400 outline-none"
              />
              <button
                type="submit"
                class="w-full bg-slate-700 hover:bg-red-500 hover:text-white text-slate-300 font-bold py-3 rounded-xl transition"
              >
                Leiratkozás megerősítése
              </button>
            </form>
          )}
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
