---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
type ExpertRow = { id: number; name: string; role: string; linkedin_url?: string | null; is_founder?: number | null; };
let experts: ExpertRow[] = [];

if (db) {
  try {
    const result = await db.prepare("SELECT * FROM experts ORDER BY is_founder DESC, created_at ASC").all();
    experts = result.results || [];
  } catch (e) {
    console.error("Experts query error:", e);
  }
}

const founder = experts.find(e => e.is_founder);
const regularExperts = experts.filter(e => !e.is_founder);
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Szakértőink | MIEF</title>
    <meta
      name="description"
      content="A MIEF szakértői közössége - különböző területek szakemberei a felelős mesterséges intelligenciáért."
    />
  </head>

  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased selection:bg-cyan-500/30">
    <Navbar />

    <main class="py-24">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl mb-6">
            Szakértőink
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed">
            A MIEF szakértői különböző területekről érkeznek. A közös pont az, hogy a mesterséges intelligencia hatásait nem elszigetelt technológiai kérdésként, hanem jogi, etikai, társadalmi, oktatási, biztonsági és szervezeti kihívásként vizsgálják.
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 max-w-7xl mx-auto">
          {/* Alapító - Kiemelten */}
          {founder && (
            <div class="col-span-full mb-12 rounded-3xl border border-cyan-400/20 bg-cyan-400/5 p-8 flex flex-col md:flex-row md:items-center justify-between gap-6 shadow-lg shadow-cyan-500/5">
              <div>
                <span class="text-xs font-bold uppercase tracking-tighter text-cyan-400 mb-2 block">Alapító</span>
                <h2 class="text-3xl font-bold text-white italic">{founder.name}</h2>
                <p class="mt-2 text-slate-300 leading-relaxed text-lg">
                  {founder.role}
                </p>
              </div>
              {founder.linkedin_url && (
                <a href={founder.linkedin_url} target="_blank" class="shrink-0 inline-flex items-center gap-2 rounded-xl bg-white/5 border border-white/10 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10 hover:border-cyan-400/50">
                  <svg class="h-6 w-6 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                  LinkedIn profil
                </a>
              )}
            </div>
          )}

          {/* További szakértők */}
          {regularExperts.length > 0 ? (
            regularExperts.map((expert) => (
              <div class="group rounded-2xl border border-white/10 bg-white/5 p-8 transition hover:border-cyan-400/50 hover:bg-white/[0.07] flex flex-col h-full shadow-lg">
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition mb-2">{expert.name}</h3>
                  <p class="text-sm text-slate-400 leading-relaxed italic mb-6">
                    {expert.role}
                  </p>
                  
                  <div class="space-y-4 pt-4 border-t border-white/5">
                    <div>
                      <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 block mb-1">Kulcstéma</span>
                      <p class="text-xs text-slate-300">Feltöltés alatt...</p>
                    </div>
                    <div>
                      <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 block mb-1">Miben kereshető</span>
                      <p class="text-xs text-slate-300">Feltöltés alatt...</p>
                    </div>
                  </div>
                </div>
                
                <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between">
                  <span class="text-[10px] font-bold text-cyan-400 bg-cyan-400/10 px-2 py-1 rounded">Szakértő</span>
                  {expert.linkedin_url ? (
                    <a href={expert.linkedin_url} target="_blank" class="inline-flex items-center gap-1.5 text-xs text-cyan-400 hover:text-cyan-300 transition font-medium">
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                      LinkedIn
                    </a>
                  ) : (
                    <span class="text-[10px] text-slate-500 italic">MIEF Tag</span>
                  )}
                </div>
              </div>
            ))
          ) : (
            <div class="col-span-full py-24 text-center">
              <p class="text-slate-500 italic text-xl">Szakértői profiljaink feltöltése folyamatban...</p>
            </div>
          )}
        </div>

        <div class="mt-24 max-w-3xl mx-auto p-8 rounded-3xl border border-dashed border-white/10 text-center">
          <h4 class="text-xl font-bold text-white mb-4">Csatlakoznál szakértői közösségünkhöz?</h4>
          <p class="text-slate-400 mb-8 leading-relaxed">
            A MIEF folyamatosan várja a mesterséges intelligencia etikai, jogi és társadalmi hatásai iránt elkötelezett szakembereket.
          </p>
          <a href="/#regisztracio" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-bold transition">
            Jelentkezés a műhelybe 
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
