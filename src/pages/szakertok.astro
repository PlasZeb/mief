---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ExpertCard from '../components/ExpertCard.astro';
import CTA from '../components/CTA.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
type ExpertRow = {
  id: number;
  name: string;
  role: string;
  linkedin_url?: string | null;
  is_founder?: number | null;
  image_url?: string | null;
  display_order?: number | null;
};

const normalizeImageUrl = (url?: string | null) => {
  const trimmed = url?.trim();
  if (!trimmed) return null;
  if (/^(https?:|data:|\/)/i.test(trimmed)) return trimmed;
  return `/${trimmed}`;
};

let experts: ExpertRow[] = [];

if (db) {
  try {
    const result = await db.prepare('SELECT * FROM experts ORDER BY is_founder DESC, display_order ASC, created_at ASC').all();
    experts = result.results || [];
  } catch (e) {
    console.error('Experts query error:', e);
  }
}

const founders = experts.filter((e) => e.is_founder);
const regularExperts = experts.filter((e) => !e.is_founder);
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Szakértőink | MIEF</title>
    <meta
      name="description"
      content="A MIEF szakértői közössége - különböző területek szakemberei a felelős mesterséges intelligenciáért."
    />
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <Navbar />

    <main>
      <Hero
        eyebrow="Szakértői közösség"
        title="Szakértőink"
        description="A MIEF különböző területekről érkező szakembereket kapcsol össze. A közös pont az, hogy a mesterséges intelligencia hatásait nem elszigetelt technológiai kérdésként, hanem jogi, etikai, társadalmi, oktatási, biztonsági és szervezeti kihívásként vizsgálják."
        primaryAction={{ label: 'Csatlakozás a műhelyhez', href: '/#regisztracio' }}
        secondaryAction={{ label: 'Vissza a főoldalra', href: '/' }}
        statLine={`Összes szakértő: ${experts.length}`}
      />

      <section class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <SectionHeader
            eyebrow="A közösség magja"
            title="A MIEF szakértői"
            description="A szakértők egységes kártyarendszerben jelennek meg."
          />

          {founders.length > 0 && (
            <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
              {founders.map((founder) => (
                <ExpertCard
                  name={founder.name}
                  role={founder.role}
                  linkedinUrl={founder.linkedin_url}
                  imageUrl={normalizeImageUrl(founder.image_url)}
                  founder
                />
              ))}
            </div>
          )}

          <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {regularExperts.length > 0 ? (
              regularExperts.map((expert) => (
                <ExpertCard
                  name={expert.name}
                  role={expert.role}
                  linkedinUrl={expert.linkedin_url}
                  imageUrl={normalizeImageUrl(expert.image_url)}
                />
              ))
            ) : (
              <p class="col-span-full py-20 text-center text-slate-500 italic">Még nincs megjelenített szakértő.</p>
            )}
          </div>
        </div>
      </section>

      <section class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <CTA
            title="Csatlakoznál szakértői közösségünkhöz?"
            description="A MIEF folyamatosan várja a mesterséges intelligencia etikai, jogi és társadalmi hatásai iránt elkötelezett szakembereket."
            buttonLabel="Jelentkezés a műhelybe"
            buttonHref="/#regisztracio"
            secondaryLabel="Vissza a főoldalra"
            secondaryHref="/"
          />
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
