---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// @ts-ignore
import { env as cfEnv } from 'cloudflare:workers';

const env = (Astro.locals as any).runtime?.env || cfEnv;
const db = env?.mief_db;
let documents: any[] = [];

if (db) {
  try {
    const { results } = await db.prepare("SELECT * FROM documents ORDER BY published_at DESC").all();
    documents = results || [];
  } catch (e) {
    console.error("DB error:", e);
  }
}

const briefs = documents.filter(d => d.type === 'brief');
const ajanlasok = documents.filter(d => d.type === 'ajanlas');
const allasfoglalasok = documents.filter(d => d.type === 'allasfoglalas');
const egyeb = documents.filter(d => d.type === 'egyeb');
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Publikációk és Szakmai Anyagok | MIEF</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased selection:bg-cyan-500/30 selection:text-cyan-200">
    <Navbar />

    <main class="pt-24 pb-20 sm:pt-32 sm:pb-32">
      <div class="container mx-auto px-6">
        
        {/* Fejléc */}
        <div class="max-w-3xl mb-16 sm:mb-24">
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white mb-6">
            Publikációk és <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Szakmai Anyagok</span>
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed">
            Itt találod a MIEF keretein belül született független szakmai háttéranyagokat, elemzéseket (MIEF Briefs), iparági ajánlásokat és állásfoglalásokat a mesterséges intelligencia felelős használatáról.
          </p>
        </div>

        <div class="grid gap-16 lg:grid-cols-12">
          
          {/* Tartalomjegyzék (Sidebar) */}
          <div class="lg:col-span-3">
            <div class="sticky top-32">
              <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-6">Kategóriák</h3>
              <nav class="flex flex-col gap-3">
                <a href="#briefs" class="text-slate-300 hover:text-cyan-400 transition font-medium">MIEF Briefs ({briefs.length})</a>
                <a href="#ajanlasok" class="text-slate-300 hover:text-indigo-400 transition font-medium">Ajánlások ({ajanlasok.length})</a>
                <a href="#allasfoglalasok" class="text-slate-300 hover:text-amber-400 transition font-medium">Állásfoglalások ({allasfoglalasok.length})</a>
                {egyeb.length > 0 && <a href="#egyeb" class="text-slate-300 hover:text-slate-100 transition font-medium">Egyéb anyagok ({egyeb.length})</a>}
              </nav>
            </div>
          </div>

          {/* Dokumentum Listák */}
          <div class="lg:col-span-9 space-y-24">
            
            {/* MIEF Briefs */}
            <section id="briefs" class="scroll-mt-32">
              <div class="flex items-center gap-4 mb-8 border-b border-white/10 pb-4">
                <div class="h-8 w-8 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <h2 class="text-2xl font-bold text-white">MIEF Briefs</h2>
              </div>
              
              <div class="grid gap-4">
                {briefs.length === 0 ? <p class="text-slate-500 italic">Jelenleg nincs feltöltött elemzés.</p> : briefs.map(doc => (
                  <a href={doc.url} target="_blank" class="group block bg-slate-800/50 border border-white/5 rounded-2xl p-6 hover:bg-slate-800 hover:border-cyan-500/30 transition shadow-lg">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                      <div>
                        <span class="text-xs font-bold text-cyan-400 mb-2 block">PUBLIKÁLVA: {doc.published_at}</span>
                        <h3 class="text-lg font-bold text-white group-hover:text-cyan-300 transition">{doc.title}</h3>
                      </div>
                      <span class="shrink-0 bg-white/5 group-hover:bg-cyan-500 group-hover:text-slate-900 text-white text-sm font-bold px-4 py-2 rounded-lg transition inline-flex items-center gap-2">
                        PDF Megnyitása &rarr;
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>

            {/* Ajánlások */}
            <section id="ajanlasok" class="scroll-mt-32">
              <div class="flex items-center gap-4 mb-8 border-b border-white/10 pb-4">
                <div class="h-8 w-8 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                </div>
                <h2 class="text-2xl font-bold text-white">Szakmai Ajánlások</h2>
              </div>
              
              <div class="grid gap-4">
                {ajanlasok.length === 0 ? <p class="text-slate-500 italic">Jelenleg nincs feltöltött ajánlás.</p> : ajanlasok.map(doc => (
                  <a href={doc.url} target="_blank" class="group block bg-slate-800/50 border border-white/5 rounded-2xl p-6 hover:bg-slate-800 hover:border-indigo-500/30 transition shadow-lg">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                      <div>
                        <span class="text-xs font-bold text-indigo-400 mb-2 block">PUBLIKÁLVA: {doc.published_at}</span>
                        <h3 class="text-lg font-bold text-white group-hover:text-indigo-300 transition">{doc.title}</h3>
                      </div>
                      <span class="shrink-0 bg-white/5 group-hover:bg-indigo-500 group-hover:text-white text-white text-sm font-bold px-4 py-2 rounded-lg transition inline-flex items-center gap-2">
                        PDF Megnyitása &rarr;
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>

            {/* Állásfoglalások */}
            <section id="allasfoglalasok" class="scroll-mt-32">
              <div class="flex items-center gap-4 mb-8 border-b border-white/10 pb-4">
                <div class="h-8 w-8 rounded-lg bg-amber-500/20 flex items-center justify-center text-amber-400">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                </div>
                <h2 class="text-2xl font-bold text-white">Állásfoglalások</h2>
              </div>
              
              <div class="grid gap-4">
                {allasfoglalasok.length === 0 ? <p class="text-slate-500 italic">Jelenleg nincs feltöltött állásfoglalás.</p> : allasfoglalasok.map(doc => (
                  <a href={doc.url} target="_blank" class="group block bg-slate-800/50 border border-white/5 rounded-2xl p-6 hover:bg-slate-800 hover:border-amber-500/30 transition shadow-lg">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                      <div>
                        <span class="text-xs font-bold text-amber-400 mb-2 block">PUBLIKÁLVA: {doc.published_at}</span>
                        <h3 class="text-lg font-bold text-white group-hover:text-amber-300 transition">{doc.title}</h3>
                      </div>
                      <span class="shrink-0 bg-white/5 group-hover:bg-amber-500 group-hover:text-slate-900 text-white text-sm font-bold px-4 py-2 rounded-lg transition inline-flex items-center gap-2">
                        PDF Megnyitása &rarr;
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>

            {/* Egyéb */}
            {egyeb.length > 0 && (
              <section id="egyeb" class="scroll-mt-32">
                <div class="flex items-center gap-4 mb-8 border-b border-white/10 pb-4">
                  <div class="h-8 w-8 rounded-lg bg-slate-500/20 flex items-center justify-center text-slate-400">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                  </div>
                  <h2 class="text-2xl font-bold text-white">Egyéb anyagok</h2>
                </div>
                
                <div class="grid gap-4">
                  {egyeb.map(doc => (
                    <a href={doc.url} target="_blank" class="group block bg-slate-800/50 border border-white/5 rounded-2xl p-6 hover:bg-slate-800 hover:border-slate-500/50 transition shadow-lg">
                      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <div>
                          <span class="text-xs font-bold text-slate-400 mb-2 block">PUBLIKÁLVA: {doc.published_at}</span>
                          <h3 class="text-lg font-bold text-white group-hover:text-slate-300 transition">{doc.title}</h3>
                        </div>
                        <span class="shrink-0 bg-white/5 group-hover:bg-slate-500 group-hover:text-white text-white text-sm font-bold px-4 py-2 rounded-lg transition inline-flex items-center gap-2">
                          Megnyitás &rarr;
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            )}

          </div>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
