---
import '../../../styles/global.css';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const { key } = Astro.params;

if (!key) {
  return Astro.redirect('/tudastar');
}

const bucket = (env as any).DOCUMENTS_BUCKET;
const kv = (env as any).DOCUMENTS;
const downloadUrl = `/docs/${key}`;

const toBase64 = (bytes: Uint8Array) => {
  let binary = '';
  const chunkSize = 0x8000;

  for (let i = 0; i < bytes.length; i += chunkSize) {
    binary += String.fromCharCode(...bytes.subarray(i, i + chunkSize));
  }

  return btoa(binary);
};

let pdfDataUrl = '';
let statusMessage = '';

try {
  if (bucket) {
    const object = await bucket.get(key);
    if (object) {
      const bytes = new Uint8Array(await object.arrayBuffer());
      const mimeType = object.httpMetadata?.contentType || 'application/pdf';
      pdfDataUrl = `data:${mimeType};base64,${toBase64(bytes)}`;
    }
  }

  if (!pdfDataUrl && kv) {
    const pdfBuffer = await kv.get(key, { type: 'arrayBuffer' });
    if (pdfBuffer) {
      pdfDataUrl = `data:application/pdf;base64,${toBase64(new Uint8Array(pdfBuffer))}`;
    }
  }

  if (!pdfDataUrl) {
    statusMessage = 'A dokumentum nem található a tárolóban.';
  }
} catch (error) {
  console.error('Error loading document preview:', error);
  statusMessage = 'A dokumentum előnézete jelenleg nem tölthető be.';
}
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Dokumentum megtekintése | MIEF</title>
    <meta name="description" content="MIEF dokumentum megnyitása és megtekintése." />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <Navbar />

    <main class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-6">
        <section class="panel p-6 sm:p-8">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="section-kicker">Dokumentum</p>
              <h1 class="section-heading">PDF megtekintése</h1>
              <p class="section-intro">A dokumentum a lapon belül jelenik meg. Ha a böngésző nem támogatja az előnézetet, a PDF külön is megnyitható ugyanerről az oldalról.</p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a href={downloadUrl} download class="button-primary">PDF letöltése</a>
              <a href="/tudastar" class="button-secondary">Vissza a tudástárra</a>
            </div>
          </div>

          {statusMessage ? (
            <div class="mt-8 rounded-3xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-900">
              {statusMessage}
            </div>
          ) : (
            <div class="mt-8 overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-100">
              <iframe src={pdfDataUrl} class="h-[78vh] w-full" title="Dokumentum előnézet"></iframe>
            </div>
          )}
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
