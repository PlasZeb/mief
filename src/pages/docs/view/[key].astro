---
import '../../../styles/global.css';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

// @ts-ignore
import { env as cfEnv } from 'cloudflare:workers';

const { key } = Astro.params;

if (!key) {
  return Astro.redirect('/tudastar');
}

const runtimeEnv = (Astro.locals as any)?.runtime?.env;
const directLocals = (Astro.locals as any)?.DOCUMENTS ? (Astro.locals as any) : null;
const env = runtimeEnv || directLocals || cfEnv || (typeof globalThis !== 'undefined' ? globalThis : {});
const kv = env.DOCUMENTS;

let pdfDataUrl: string | null = null;

if (kv) {
  const pdfBuffer = await kv.get(key, { type: 'arrayBuffer' });
  if (pdfBuffer) {
    const bytes = new Uint8Array(pdfBuffer);
    let binary = '';
    for (let i = 0; i < bytes.length; i++) {
      binary += String.fromCharCode(bytes[i]);
    }
    pdfDataUrl = `data:application/pdf;base64,${btoa(binary)}`;
  }
}

const viewerUrl = `/docs/view/${key}`;
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Dokumentum megtekintése | MIEF</title>
    <meta name="description" content="MIEF dokumentum megnyitása és megtekintése." />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <Navbar />

    <main class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-6">
        <section class="panel p-6 sm:p-8">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="section-kicker">Dokumentum</p>
              <h1 class="section-heading">PDF megtekintése</h1>
              <p class="section-intro">A dokumentum a lapon belül jelenik meg. Ha a böngésző nem támogatja az előnézetet, a PDF külön is megnyitható ugyanerről az oldalról.</p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a href={viewerUrl} target="_blank" rel="noreferrer" class="button-primary">Megnyitás új lapon</a>
              <a href="/tudastar" class="button-secondary">Vissza a tudástárra</a>
            </div>
          </div>

          <div class="mt-8 overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-100">
            {pdfDataUrl ? (
              <iframe
                src={pdfDataUrl}
                class="h-[78vh] w-full"
                title="Dokumentum előnézet"
              ></iframe>
            ) : (
              <div class="flex h-[78vh] items-center justify-center p-8 text-center">
                <div>
                  <p class="text-lg font-semibold text-slate-950">A dokumentum nem érhető el.</p>
                  <p class="mt-2 text-sm text-slate-600">Lehet, hogy a fájl nincs meg a dokumentumtárolóban, vagy a binding nincs konfigurálva.</p>
                </div>
              </div>
            )}
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
