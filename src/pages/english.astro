---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>English Summary | MIEF</title>
    <meta
      name="description"
      content="MIEF - AI Ethics Forum: Independent, interdisciplinary professional community and workshop dedicated to responsible AI in Hungary."
    />
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <Navbar />

    <main>
      <Hero
        eyebrow="English Summary"
        title="MIEF - where AI turns from technology into social responsibility"
        description="MIEF - AI Ethics Forum - is an independent, interdisciplinary professional community and workshop dedicated to the responsible, transparent and human-centred use of artificial intelligence in Hungary."
        primaryAction={{ label: 'Contact us', href: 'mailto:info@mief.hu' }}
        secondaryAction={{ label: 'Back to homepage', href: '/' }}
      />

      <section class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <SectionHeader
            eyebrow="About us"
            title="A professional forum for responsible AI"
            description="We examine the social, legal, ethical, and security implications of AI and connect experts from law, IT, education, philosophy, research, business, and security policy."
            center
          />

          <div class="mt-12 grid gap-6 md:grid-cols-2">
            <div class="panel p-8">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Multidisciplinary</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">Our strength lies in diversity, allowing us to examine AI not just as code, but as a force shaping the fabric of society.</p>
            </div>
            <div class="panel p-8">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Independent</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">As a civil professional forum, we strive to be guided by professional arguments and public interest rather than narrow business interests.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="border-y border-slate-200 bg-slate-50/80 py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <CTA
            title="Interested in international collaboration?"
            description="We are open to partnerships with international AI ethics organizations, research centers, and policy workshops."
            buttonLabel="Contact us at info@mief.hu"
            buttonHref="mailto:info@mief.hu"
            secondaryLabel="Go back to the homepage"
            secondaryHref="/"
          />
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
