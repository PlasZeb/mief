---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EventCard from '../components/EventCard.astro';
import CTA from '../components/CTA.astro';
import Card from '../components/Card.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

type EventItem = {
  date: string;
  title: string;
  description: string;
  join_url?: string | null;
};

type ProgramItem = {
  date: string;
  title: string;
  location?: string | null;
  notes?: string | null;
  url?: string | null;
  speaker?: string | null;
  is_featured?: number | null;
};

const db = (env as any)?.mief_db;
let allEvents: EventItem[] = [];
let recommendedPrograms: ProgramItem[] = [];
let submissionStatus = null;
let subscribeStatus = null;

if (db) {
  try {
    const result = await db.prepare('SELECT * FROM events').all();
    allEvents = (result.results || []) as EventItem[];
  } catch (e) {
    console.error('Database query error:', e);
  }

  try {
    const result = await db.prepare('SELECT * FROM programs ORDER BY date ASC').all();
    recommendedPrograms = (result.results || []) as ProgramItem[];
  } catch (e) {
    console.error('Programs query error:', e);
  }
}

const now = new Date();
const upcomingEvents = allEvents.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('form_action');

    if (action === 'register') {
      const name = data.get('name');
      const email = data.get('email');
      const professionSelect = data.get('profession');
      const professionCustom = data.get('profession_custom');
      const finalProfession = professionSelect === 'other' ? professionCustom : professionSelect;

      if (db && name && email && finalProfession) {
        await db.prepare('INSERT INTO registrations (name, email, profession) VALUES (?, ?, ?)')
          .bind(name, email, String(finalProfession))
          .run();
        submissionStatus = 'success';
      } else {
        submissionStatus = 'error';
      }
    } else if (action === 'subscribe') {
      const name = data.get('name');
      const email = data.get('email');
      if (db && name && email) {
        await db.prepare("INSERT OR IGNORE INTO subscribers (name, email, status) VALUES (?, ?, 'pending')")
          .bind(name, email)
          .run();
        subscribeStatus = 'success';
      } else {
        subscribeStatus = 'error';
      }
    }
  } catch (error) {
    console.error('Form error:', error);
    submissionStatus = 'error';
    subscribeStatus = 'error';
  }
}
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>MI Etika Fórum | MIEF</title>
    <meta
      name="description"
      content="Az MI Etika Fórum szakmai közösség a mesterséges intelligencia felelős, átlátható és emberközpontú alkalmazásáról."
    />
  </head>

  <body id="top" class="min-h-screen bg-slate-50 text-slate-900 antialiased selection:bg-cyan-500/20 selection:text-cyan-950">
    <Navbar />

    <main>
      <Hero
        eyebrow="Szakmai közösség"
        title="MIEF - ahol az MI technológiai kérdésből társadalmi felelősséggé válik"
        description="A MIEF független, interdiszciplináris szakmai műhely, amely jogi, technológiai, oktatási, filozófiai, üzleti és biztonságpolitikai nézőpontból vizsgálja a mesterséges intelligencia hatásait."
        primaryAction={{ label: 'Csatlakozás a műhelyhez', href: '#regisztracio' }}
        secondaryAction={{ label: 'Események megtekintése', href: '#esemenyek' }}
        imageSrc="/assets/logo.jpg"
        imageAlt="MIEF logó"
        statLine="Világos intézményi alap, mély tengerészkék hangsúlyok és cián akcentus a MIEF új arculatában."
      />

      <section class="border-y border-slate-200 bg-slate-50/80">
        <div class="mx-auto max-w-7xl px-6 py-8">
          <div class="grid gap-4 md:grid-cols-3">
            <div class="panel-soft px-5 py-4">
              <p class="micro-label text-cyan-700">Interdiszciplináris műhely</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Jogi, technológiai, oktatási és biztonságpolitikai nézőpontok egy közös szakmai térben.</p>
            </div>
            <div class="panel-soft px-5 py-4">
              <p class="micro-label text-cyan-700">Független fórum</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Szakmai érvek mentén működő közösség, pártpolitikai és szűk üzleti kötöttség nélkül.</p>
            </div>
            <div class="panel-soft px-5 py-4">
              <p class="micro-label text-cyan-700">Nyitott csatlakozás</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Szakértőknek, kutatóknak és gyakorlati döntéshozóknak, akik felelős MI-használatban gondolkodnak.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="miert" class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
            <SectionHeader
              eyebrow="Kik vagyunk?"
              title="Egy szakmai tér, ahol a technológia és a közjó találkozik"
              description="A MIEF olyan független közösség és műhely, amely a mesterséges intelligencia társadalmi, jogi, etikai és biztonsági következményeit vizsgálja."
            />

            <div class="panel p-7 sm:p-8">
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                  <p class="micro-label text-cyan-700">Közös platform</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">Jogászok, informatikusok, pedagógusok, filozófusok, kutatók és döntéshozók egy asztalnál.</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                  <p class="micro-label text-cyan-700">Alkalmazható tudás</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">Ajánlások, háttéranyagok, képzési anyagok és gyakorlati eszközök formájában.</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 sm:col-span-2">
                  <p class="micro-label text-cyan-700">Bővíthető rendszer</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">A tartalmi és vizuális réteg külön van választva, így a site könnyen tovább építhető.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-14 grid gap-6 md:grid-cols-3">
            <div class="panel p-6">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Valódi interdiszciplinaritás</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">Nem egyetlen szakterület logikájára építünk, hanem többféle szakmai nézőpontot kapcsolunk össze.</p>
            </div>
            <div class="panel p-6">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Független szakmai működés</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">A szakmai érvek, a közérdek és az emberi méltóság szempontjai vezetik a közös munkát.</p>
            </div>
            <div class="panel p-6">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Gyakorlati fókusz</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">Rövid háttéranyagok, esettanulmányok, ellenőrzőlisták és ajánlások segítik a mindennapi döntéseket.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="kinek" class="border-y border-slate-200 bg-slate-50/80 py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="max-w-3xl">
            <SectionHeader
              eyebrow="Miért fontos az MI-etika?"
              title="Interdiszciplináris válaszok a jövő kihívásaira"
              description="A MIEF értéke abban áll, hogy különböző szakmai nézőpontokat kapcsol össze, és ezekből közérthető, gyakorlati és felelősségteljes válaszokat keres."
            />
          </div>

          <div class="mt-12 grid gap-6 md:grid-cols-3">
            <div class="panel p-7">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Valódi interdiszciplinaritás</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">A szakmai határterületeket nem külön kezeljük, hanem egy közös értelmezési térben kapcsoljuk össze.</p>
            </div>
            <div class="panel p-7">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Független szakmai működés</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">A közösség működését a szakmai minőség és a közérdek tartja össze.</p>
            </div>
            <div class="panel p-7">
              <h3 class="text-xl font-semibold tracking-tight text-slate-950">Gyakorlati fókusz</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">Munkánk célja, hogy a gondolatokból használható anyagok és eszközök szülessenek.</p>
            </div>
          </div>

          <div class="mt-10 flex flex-wrap gap-2">
            {['Jogászok', 'Pedagógusok', 'IT-szakemberek', 'Filozófusok', 'Üzletemberek', 'Egyetemi oktatók', 'Kutatók', 'Katonai és biztonságpolitikai szakértők', 'További szakterületek képviselői'].map((target) => (
              <span class="rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-medium text-slate-600 shadow-sm">
                {target}
              </span>
            ))}
          </div>
        </div>
      </section>

      <section id="tudastar" class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <SectionHeader
              eyebrow="Tudástár"
              title="Szakmai anyagok és állásfoglalások"
              description="A MIEF Tudástár közérthető, szakmailag megalapozott és gyakorlati szempontból is használható anyagokat tesz közzé."
            />

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="panel p-6 sm:col-span-2">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700 ring-1 ring-cyan-100">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="micro-label text-cyan-700">MIEF Briefs</p>
                    <p class="mt-1 text-sm text-slate-600">Rövid, 2-4 oldalas háttéranyagok aktuális MI-etikai kérdésekről.</p>
                  </div>
                </div>
              </div>
              <div class="panel p-6">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-700 ring-1 ring-indigo-100">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 12v-2a1 1 0 011-1h2l8-4v14l-8-4H5a1 1 0 01-1-1v-2z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 10.5a3.5 3.5 0 010 3" />
                    </svg>
                  </div>
                  <div>
                    <p class="micro-label text-indigo-700">Állásfoglalások</p>
                    <p class="mt-1 text-sm text-slate-600">A szakértői közösség által elfogadott szakmai vélemények.</p>
                  </div>
                </div>
              </div>
              <div class="panel p-6">
                <div class="flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-700 ring-1 ring-amber-100">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 14a5 5 0 116 0c-.7.7-1.2 1.7-1.3 2.7H10.3c-.1-1-.6-2-1.3-2.7z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 20h4" />
                    </svg>
                  </div>
                  <div>
                    <p class="micro-label text-amber-700">Ajánlások</p>
                    <p class="mt-1 text-sm text-slate-600">Gyakorlati útmutatók döntéshozók és szakemberek számára.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a
              href="/tudastar"
              class="button-primary"
            >
              Tovább a tudástárhoz
            </a>
          </div>
        </div>
      </section>

      <section id="fokusz" class="border-y border-slate-200 bg-slate-50/80 py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <SectionHeader
            eyebrow="Szakértői területeink"
            title="A MIEF fókuszterületei"
            description="A közösség több szakmai nézőpontot kapcsol össze, hogy az MI társadalmi és szervezeti hatásait teljesebb képen láthassuk."
          />

          <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            <Card title="Felelős MI" description="Az emberi autonómia, méltóság és elszámoltathatóság kérdései az MI-rendszerek fejlesztésében." icon="shield" />
            <Card title="MI-szabályozás és governance" description="Az AI Act, az ISO 42001 és a hazai szabályozási környezet etikai és társadalmi értelmezése." icon="scales" />
            <Card title="Oktatás és jövő" description="Az MI hatása a tanulásra, a szakmai kompetenciákra és a felelős technológiahasználatra." icon="graduation" />
            <Card title="Kiberbiztonság és reziliencia" description="Az MI szerepe a digitális sérülékenységek és szervezeti kockázatok kezelésében." icon="building" />
            <Card title="Közszolgálat és irányítás" description="Az algoritmikus döntéstámogatás jogi és etikai következményei az állami működésben." icon="government" />
            <Card title="Média és dezinformáció" description="A deepfake, az álhírek és az algoritmikus tartalomterjesztés hatása a társadalmi bizalomra." icon="megaphone" />
            <Card title="Védelem és biztonságpolitika" description="Az MI katonai és stratégiai alkalmazásának etikai korlátai és döntéstámogatási dilemmái." icon="sword" />
          </div>
        </div>
      </section>

      <section id="esemenyek" class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <SectionHeader
              eyebrow="Műhelyek"
              title="Szakmai műhelymunkáink"
              description="Online és személyes alkalmainkon a mesterséges intelligencia legégetőbb etikai és szabályozási kérdéseit dolgozzuk fel."
            />
            <a href="/esemenyek" class="button-secondary">
              Teljes műhelytár megnyitása
            </a>
          </div>

          <div class="mt-10 grid gap-6 lg:grid-cols-2">
            {upcomingEvents.length > 0 ? (
              upcomingEvents.slice(0, 4).map((event, index) => (
                <EventCard
                  title={event.title}
                  date={new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
                  description={event.description}
                  joinUrl={event.join_url}
                  featured={index === 0}
                  past={new Date(event.date) < now}
                />
              ))
            ) : (
              <p class="text-slate-500 italic">Jelenleg nincsenek meghirdetett események. Iratkozz fel, hogy értesülj a következőről!</p>
            )}
          </div>
        </div>
      </section>

      <section id="programok" class="border-y border-slate-200 bg-slate-50/80 py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="max-w-3xl">
            <SectionHeader
              eyebrow="Programajánló"
              title="Szakmai események, konferenciák, fesztiválok"
              description="Válogatott külsős események, amelyeket ajánlunk az érdeklődőknek."
            />
          </div>

          <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {recommendedPrograms.length > 0 ? (
              recommendedPrograms.map((program) => (
                <EventCard
                  title={program.title}
                  date={program.date}
                  location={program.location}
                  description={`${program.notes ?? 'Ajánlott program a MIEF közösségének.'}${program.speaker ? `\nElőadó: ${program.speaker}` : ''}`}
                  joinUrl={program.url}
                  featured={Boolean(program.is_featured)}
                />
              ))
            ) : (
              <p class="col-span-full text-slate-500 italic text-center py-12">Jelenleg nincsenek rögzített külső programok.</p>
            )}
          </div>

          <div class="mt-10 max-w-2xl">
            <div class="panel-soft p-7 text-center">
              <h3 class="text-2xl font-semibold tracking-tight text-slate-950">Szeretnél értesülni az új programokról?</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">Iratkozz fel, és küldjük neked a legfrissebb ajánlókat.</p>

              {subscribeStatus === 'success' ? (
                <p class="mt-6 text-sm font-medium text-emerald-700">Sikeres jelentkezés. Az admin jóváhagyása után küldjük az értesítéseket.</p>
              ) : (
                <form method="POST" class="mt-6 flex flex-col gap-3 sm:flex-row">
                  <input type="hidden" name="form_action" value="subscribe" />
                  <input type="text" name="name" required placeholder="Neved" class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100" />
                  <input type="email" name="email" required placeholder="E-mail címed" class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100" />
                  <button type="submit" class="button-primary">Feliratkozás</button>
                </form>
              )}

              {subscribeStatus === 'error' && <p class="mt-4 text-sm text-red-600">Hiba történt. Kérjük próbáld újra!</p>}
            </div>
          </div>
        </div>
      </section>

      <section id="regisztracio" class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <SectionHeader
              eyebrow="Csatlakozás"
              title="Legyél a közösség tagja"
              description="A MIEF egy nyitott szakmai fórum. Ha érdekelnek az MI etikai kérdései, és szívesen részt vennél a párbeszédben vagy eseményeinken, regisztrálj."
            />

            <div class="panel p-8">
              {submissionStatus === 'success' ? (
                <div class="py-8 text-center">
                  <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-cyan-50 text-cyan-700 ring-1 ring-cyan-100">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <h3 class="mt-6 text-2xl font-semibold tracking-tight text-slate-950">Sikeres regisztráció</h3>
                  <p class="mt-3 text-sm leading-7 text-slate-600">Köszönjük a jelentkezésedet. Hamarosan keresünk!</p>
                  <a href="#top" class="mt-8 inline-flex text-sm font-semibold text-cyan-700 hover:text-cyan-600">Vissza a tetejére</a>
                </div>
              ) : (
                <form method="POST" class="grid gap-5">
                  <input type="hidden" name="form_action" value="register" />

                  <div class="grid gap-2">
                    <label for="name" class="text-sm font-medium text-slate-700">Név</label>
                    <input id="name" type="text" name="name" required placeholder="Teljes név" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100" />
                  </div>

                  <div class="grid gap-2">
                    <label for="email" class="text-sm font-medium text-slate-700">E-mail cím</label>
                    <input id="email" type="email" name="email" required placeholder="email@pelda.hu" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100" />
                  </div>

                  <div class="grid gap-2">
                    <label for="profession" class="text-sm font-medium text-slate-700">Szakterület</label>
                    <select
                      id="profession"
                      name="profession"
                      required
                      class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100"
                      onchange="document.getElementById('custom-profession-container').style.display = this.value === 'other' ? 'grid' : 'none'; document.getElementById('profession_custom').required = this.value === 'other';"
                    >
                      <option value="" disabled selected>Válassz szakterületet</option>
                      <option value="tech">Technológia / Mérnök</option>
                      <option value="legal">Jog</option>
                      <option value="edu">Oktatás</option>
                      <option value="research">Kutatás</option>
                      <option value="other">Egyéb (saját megadás)</option>
                    </select>
                  </div>

                  <div id="custom-profession-container" class="grid gap-2" style="display: none;">
                    <label for="profession_custom" class="text-sm font-medium text-slate-700">Saját szakterület megnevezése</label>
                    <input id="profession_custom" type="text" name="profession_custom" placeholder="Pl. Filozófus, Biztonságpolitika" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100" />
                  </div>

                  {submissionStatus === 'error' && <p class="text-sm text-red-600">Hiba történt a küldés során. Kérjük próbáld újra később!</p>}

                  <button type="submit" class="button-primary mt-2">Regisztráció beküldése</button>
                  <p class="text-center text-xs text-slate-500">A regisztrációval elfogadod az adatkezelési tájékoztatónkat.</p>
                </form>
              )}
            </div>
          </div>
        </div>
      </section>

      <section id="kapcsolat" class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <CTA
            dark
            title="Kérdésed van?"
            description="Szeretnél többet tudni a fórumról, vagy együttműködési javaslatod van? Keress minket bizalommal."
            buttonLabel="Kapcsolatfelvétel e-mailben"
            buttonHref="mailto:info@mief.hu"
          />
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
