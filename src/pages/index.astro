---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/Card.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
let allEvents = [];
let dbError = null;

if (db) {
  try {
    const result = await db.prepare("SELECT * FROM events").all();
    allEvents = result.results || [];
  } catch (e) {
    console.error("Database query error:", e);
    dbError = "Nem sikerült betölteni az eseményeket.";
  }
}

// Szakértők lekérése
let experts = [];
if (db) {
  try {
    const result = await db.prepare("SELECT * FROM experts ORDER BY created_at ASC").all();
    experts = result.results || [];
  } catch (e) {
    console.error("Experts query error:", e);
  }
}

const upcomingEvents = allEvents
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

let submissionStatus = null;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name");
    const email = data.get("email");
    const professionSelect = data.get("profession");
    const professionCustom = data.get("profession_custom");
    
    const finalProfession = professionSelect === "other" ? professionCustom : professionSelect;

    if (db && name && email && finalProfession) {
      await db.prepare("INSERT INTO registrations (name, email, profession) VALUES (?, ?, ?)")
        .bind(name, email, String(finalProfession))
        .run();
      submissionStatus = "success";
    } else {
      submissionStatus = "error";
    }
  } catch (error) {
    console.error("Registration error:", error);
    submissionStatus = "error";
  }
}
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MI Etika Fórum | MIEF</title>
    <meta
      name="description"
      content="Az MI Etika Fórum szakmai közösség a mesterséges intelligencia felelős, átlátható és emberközpontú alkalmazásáról."
    />
  </head>

  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased selection:bg-cyan-500/30">
    <Navbar />

    <main>
      {/* Hero Section */}
      <section class="relative min-h-[80vh] flex items-center overflow-hidden border-b border-white/5">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(34,211,238,0.05),transparent_50%)]"></div>
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>

        <div class="container mx-auto px-6 relative z-10 py-24 sm:py-32">
          <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
            <div>
              <div class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-1.5 text-sm font-medium text-cyan-300">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
                </span>
                Szakmai közösség
              </div>

              <h1 class="mt-8 text-5xl font-extrabold tracking-tight text-white sm:text-7xl">
                MI Etika <br />
                <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Fórum</span>
              </h1>

              <p class="mt-8 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
                A mesterséges intelligencia felelős, átlátható és emberközpontú alkalmazásáról — technológiai, jogi, oktatási, filozófiai és biztonságpolitikai nézőpontból.
              </p>

              <div class="mt-10 flex flex-col gap-4 sm:flex-row">
                <a
                  href="#regisztracio"
                  class="rounded-xl bg-cyan-400 px-8 py-4 text-center text-sm font-bold text-slate-900 shadow-xl shadow-cyan-500/20 transition hover:bg-cyan-300 hover:scale-105 active:scale-95"
                >
                  Regisztráció tagnak
                </a>
                <a
                  href="#esemenyek"
                  class="rounded-xl border border-white/10 bg-white/5 px-8 py-4 text-center text-sm font-bold text-white backdrop-blur-sm transition hover:bg-white/10"
                >
                  Események
                </a>
              </div>
            </div>

            {/* Image Illustration */}
            <div class="relative hidden lg:block">
              <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 blur-3xl"></div>
              <div class="relative rounded-3xl border border-white/10 bg-slate-800/50 p-4 backdrop-blur-2xl overflow-hidden">
                 <img src="/assets/logo.jpg" alt="MIEF Illustration" class="w-full h-auto rounded-2xl shadow-2xl opacity-90 transition hover:scale-105 duration-700" />
              </div>
              <div class="absolute -bottom-6 -right-6 h-32 w-32 rounded-full border border-cyan-400/20 bg-cyan-400/10 blur-xl"></div>
              <div class="absolute -top-6 -left-6 h-32 w-32 rounded-full border border-blue-400/20 bg-blue-400/10 blur-xl"></div>
            </div>
          </div>
        </div>
      </section>

      {/* Küldetés Section */}
      <section id="miert" class="py-24 relative overflow-hidden">
        <div class="container mx-auto px-6">
          <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Küldetés</h2>
            <p class="mt-6 text-2xl font-medium text-slate-300 italic italic">
              "Az MI társadalmi, jogi és filozófiai etikai hatásainak elemzése; felelős és átlátható MI-megoldások ösztönzése."
            </p>
            <p class="mt-10 text-lg leading-relaxed text-slate-300">
              Az <strong>Interdiszciplináris Párbeszédek az MI Felelősségéről és Irányításáról (IPMFI)</strong> az MI Etika Fórum (MIEF) keretében futó, annak civil szervezetként létrejöttét segítő projekt küldetése, hogy hidat képezzen a technológiai innováció és a társadalmi-etikai felelősségvállalás között.
            </p>
            <p class="mt-6 text-lg leading-relaxed text-slate-300">
              Hiszünk abban, hogy a mesterséges intelligencia térnyerése nem csupán mérnöki kérdés, hanem olyan komplex kihívás, amelyre csak közösen, több tudományterület összefogásával adhatunk érvényes válaszokat.
            </p>
            <p class="mt-6 text-slate-400">
              Ezért jött létre 2026 januárjában az a multidiszciplináris fórum, amely független civil szerveződés alapon szerveződik online és személyes alkalmakat tartva.
            </p>
          </div>
        </div>
      </section>

      {/* Kinek szól? Section */}
      <section id="kinek" class="py-24 border-y border-white/5 bg-slate-950/50">
        <div class="container mx-auto px-6">
          <div class="mb-16 text-center max-w-3xl mx-auto">
            <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Kik vagyunk</h2>
            <h3 class="mt-4 text-3xl font-bold text-white">Független szakmai közösség</h3>
            <p class="mt-6 text-slate-300">
              Műhelyünk egy olyan közösség, ahol a legkülönbözőbb területek képviselio dolgoznak együtt. Közösségünk erejét a sokszínűség adja, lehetővé téve, hogy az MI-t ne csak kódként, hanem a társadalom szövetét alakító tényezőként vizsgáljuk.
            </p>
          </div>
          
          <div class="flex flex-wrap justify-center gap-4 max-w-5xl mx-auto">
            {['Jogászok', 'Pedagógusok', 'IT-szakemberek', 'Filozófusok', 'Üzletemberek', 'Egyetemi oktatók', 'Kutatók', 'Katonai és biztonságpolitikai szakértők'].map((target) => (
              <span class="rounded-full border border-white/10 bg-white/5 px-6 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-400/50 hover:bg-cyan-400/10 hover:text-cyan-300">
                {target}
              </span>
            ))}
          </div>
        </div>
      </section>

      {/* Members & Experts Section */}
      <section id="tagok" class="py-24 relative overflow-hidden">
        <div class="container mx-auto px-6">
          <div class="mb-16 text-center">
            <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Tagjaink és Szakértőink</h2>
            <h3 class="mt-4 text-3xl font-bold text-white">Akik a párbeszédet építik</h3>
            <p class="mt-4 text-slate-400">Taglétszám jelenleg: 32 fő</p>
          </div>

          <div class="max-w-5xl mx-auto">
            {/* Founder */}
            <div class="mb-16 rounded-3xl border border-cyan-400/20 bg-cyan-400/5 p-8 flex flex-col md:flex-row md:items-center justify-between gap-6 shadow-lg shadow-cyan-500/5">
              <div>
                <span class="text-xs font-bold uppercase tracking-tighter text-cyan-400 mb-2 block">Alapító</span>
                <h4 class="text-2xl font-bold text-white italic">Dr. Markovics Milán Mór</h4>
                <p class="mt-2 text-slate-300 leading-relaxed">
                  filozófus-MI etika kutató, egyetemi oktató (NKE)
                </p>
              </div>
              <a href="https://www.linkedin.com/in/milan-mor-markovics-750149161/" target="_blank" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 transition font-medium">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                LinkedIn profil
              </a>
            </div>

            <div class="mb-8">
              <h4 class="text-xl font-bold text-white mb-2">Nyilvános szakértőink</h4>
              <p class="text-sm text-slate-400 italic">A nyilvánosságot vállaló tagok folyamatosan kerülnek feltöltésre.</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {experts.length > 0 ? (
                experts.map((expert: any) => (
                  <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition group">
                    <h5 class="font-bold text-white group-hover:text-cyan-400 transition">{expert.name}</h5>
                    <p class="mt-2 text-xs text-slate-400 leading-normal">{expert.role}</p>
                  </div>
                ))
              ) : (
                <div class="col-span-full py-12 text-center text-slate-500 italic border border-dashed border-white/5 rounded-2xl">
                  Szakértőink feltöltése folyamatban...
                </div>
              )}
              {experts.length > 0 && (
                <div class="rounded-2xl border border-dashed border-white/5 bg-transparent p-6 flex items-center justify-center">
                  <span class="text-slate-500 text-sm">... és további szakértők</span>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      {/* Fókuszterületek Section */}
      <section id="fokusz" class="py-24">
        <div class="container mx-auto px-6">
          <div class="mb-16 text-center max-w-3xl mx-auto">
            <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Mivel foglalkozunk</h2>
            <h3 class="mt-4 text-3xl font-bold text-white">Fókuszterületeink</h3>
            <p class="mt-6 text-slate-300">
              Rendszeres találkozóinkon és műhelymunka-alkalmainkon olyan kritikus témákat járunk körül, amelyek meghatározzák a jövőnket.
            </p>
          </div>

          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
            <Card 
              title="Felelős AI" 
              description="Hol végződik a gép és hol kezdődik az ember felelőssége az MI-rendszerek alkalmazásában."
              icon="🛡️"
            />
            <Card 
              title="Szabályozás és Irányítás" 
              description="Az ISO 42001 szabvány alkalmazása és a jogi keretrendszerek elemzése."
              icon="⚖️"
            />
            <Card 
              title="Biztonság" 
              description="Kiberbiztonsági protokollok és az MI szerepe a modern védelmi rendszerekben."
              icon="🏛️"
            />
            <Card 
              title="Oktatás és Jövő" 
              description="Hogyan készítsük fel a társadalmat az ember-gép együttműködés világára."
              icon="🎓"
            />
          </div>

          <div class="mt-20 max-w-3xl mx-auto text-center border-t border-white/5 pt-12">
             <h3 class="text-2xl font-bold text-white mb-6">Miért csatlakozz hozzánk?</h3>
             <p class="text-slate-300 leading-relaxed mb-8">
               Célunk az alapvető értékek lefektetése egy olyan világban, ahol az algoritmusok mindennapjaink részévé válnak. Az IPMFI nem csupán elméleti vitafórum, hanem egy aktív hálózat, ahol a nézőpontok ütköztetése révén valódi, alkalmazható tudás jön létre.
             </p>
             <p class="text-slate-400 italic">
               „A szakember fogalma nálunk szándékosan sokrétű – hiszen a jövőt csak közösen érthetjük meg.”
             </p>
          </div>
        </div>
      </section>

      {/* Események Section */}
      <section id="esemenyek" class="py-24 bg-slate-950/30">
        <div class="container mx-auto px-6">
          <div class="mb-16">
            <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Események</h2>
            <h3 class="mt-4 text-3xl font-bold text-white">Szakmai találkozók</h3>
          </div>

          <div class="grid gap-8 lg:grid-cols-2">
            {upcomingEvents.length > 0 ? (
              upcomingEvents.map((event) => (
                <div class="group relative rounded-3xl border border-white/10 bg-white/5 p-8 transition hover:bg-white/10">
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                      <span class="text-xs font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-2 py-1 rounded">
                        {new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
                      </span>
                      <h4 class="mt-2 text-xl font-bold text-white group-hover:text-cyan-300 transition">{event.title}</h4>
                      <p class="mt-1 text-sm text-slate-400">{event.location_url}</p>
                    </div>
                    {event.location_url && event.location_url.startsWith('http') && (
                      <a href={event.location_url} target="_blank" class="inline-flex items-center justify-center rounded-xl bg-white/10 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/20">
                        Részletek
                      </a>
                    )}
                  </div>
                  <p class="mt-6 text-slate-300 leading-relaxed whitespace-pre-wrap">
                    {event.description}
                  </p>
                </div>
              ))
            ) : (
              <p class="text-slate-400 italic text-lg">Jelenleg nincsenek meghirdetett események. Iratkozz fel, hogy értesülj a következőről!</p>
            )}
          </div>
          {dbError && <p class="mt-4 text-sm text-red-400">{dbError}</p>}
        </div>
      </section>

      {/* Regisztráció Section */}
      <section id="regisztracio" class="py-24 border-t border-white/5">
        <div class="container mx-auto px-6">
          <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
            <div>
              <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Csatlakozás</h2>
              <h3 class="mt-4 text-4xl font-bold text-white">Legyél a közösség tagja</h3>
              <p class="mt-6 text-lg text-slate-300 leading-relaxed">
                A MIEF egy nyitott szakmai fórum. Ha érdekelnek az MI etikai kérdései, és szívesen részt vennél a párbeszédben vagy eseményeinken, regisztrálj!
              </p>
              
