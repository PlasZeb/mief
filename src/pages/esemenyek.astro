---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EventCard from '../components/EventCard.astro';
import CTA from '../components/CTA.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
let allEvents = [];
let dbError = null;
let subscribeSuccess = '';
let subscribeError = '';

if (db) {
  try {
    await db.prepare('CREATE TABLE IF NOT EXISTS subscribers (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL, email TEXT NOT NULL UNIQUE, subscribed_at DATETIME DEFAULT CURRENT_TIMESTAMP)').run();
  } catch {
    // tábla már létezik
  }
}

if (Astro.request.method === 'POST' && db) {
  const data = await Astro.request.formData();
  const name = data.get('name');
  const email = data.get('email');
  if (name && email) {
    try {
      await db.prepare('INSERT INTO subscribers (name, email) VALUES (?, ?)').bind(name, email).run();
      subscribeSuccess = 'Sikeresen feliratkoztál! Értesíteni fogunk az új eseményekről.';
    } catch (e: any) {
      if (e?.message?.includes('UNIQUE')) {
        subscribeError = 'Ez az email cím már fel van iratkozva.';
      } else {
        subscribeError = 'Hiba történt a feliratkozás során. Kérjük próbáld újra.';
      }
    }
  } else {
    subscribeError = 'Kérjük add meg a neved és email címed.';
  }
}

if (db) {
  try {
    const result = await db.prepare('SELECT * FROM events').all();
    allEvents = result.results || [];
  } catch (e) {
    console.error('Database query error:', e);
    dbError = 'Nem sikerült betölteni az eseményeket.';
  }
}

const now = new Date();
const upcomingEvents = allEvents
  .filter((event: any) => new Date(event.date) >= now)
  .sort((a: any, b: any) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = allEvents
  .filter((event: any) => new Date(event.date) < now)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Műhelyek | MIEF</title>
    <meta
      name="description"
      content="A MIEF szakmai műhelymunkái, kerekasztal-beszélgetései és online alkalmainak gyűjteménye."
    />
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <Navbar />

    <main>
      <Hero
        eyebrow="Műhelyek"
        title="Szakmai műhelymunkáink"
        description="A MIEF rendszeres online és személyes alkalmakon dolgozza fel a mesterséges intelligencia etikai, jogi, társadalmi, oktatási és biztonsági kérdéseit."
        primaryAction={{ label: 'Értesítést kérek', href: '#feliratkozas' }}
        secondaryAction={{ label: 'Vissza a főoldalra', href: '/' }}
        statLine={`Összes esemény: ${allEvents.length}`}
      />

      <section class="py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <SectionHeader
            eyebrow="Tervezett műhelyek"
            title="Közelgő alkalmaink"
            description="A szakmai párbeszéd és a közös gondolkodás tere."
          />

          <div class="mt-12 grid gap-6 lg:grid-cols-2">
            {upcomingEvents.length > 0 ? (
              upcomingEvents.map((event: any, index: number) => (
                <EventCard
                  title={event.title}
                  date={new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
                  description={event.description}
                  joinUrl={event.join_url}
                  featured={index === 0}
                  past={false}
                />
              ))
            ) : (
              <p class="col-span-full rounded-3xl border border-dashed border-slate-200 bg-white p-12 text-center text-slate-500 italic">
                Jelenleg nincs új esemény meghirdetve. Iratkozz fel híreinkre, hogy értesülj a következőről.
              </p>
            )}
          </div>
        </div>
      </section>

      <section class="border-y border-slate-200 bg-slate-50/80 py-20 sm:py-24">
        <div class="mx-auto max-w-7xl px-6">
          <SectionHeader
            eyebrow="Lezajlott műhelyek"
            title="Archívum"
            description="A lezajlott alkalmak összefoglalói és leírásai."
          />

          <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {pastEvents.length > 0 ? (
              pastEvents.map((event: any) => (
                <EventCard
                  title={event.title}
                  date={new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric' })}
                  description={event.description}
                  past
                />
              ))
            ) : (
              <p class="col-span-full text-center text-slate-500 italic py-12">Nincsenek korábbi események rögzítve.</p>
            )}
          </div>

          {dbError && <p class="mt-10 rounded-2xl border border-red-200 bg-red-50 p-4 text-center text-red-700">{dbError}</p>}
        </div>
      </section>

      <section id="feliratkozas" class="py-20 sm:py-24">
        <div class="mx-auto max-w-3xl px-6">
          <CTA
            title="Értesítést kérek új eseményekről"
            description="Add meg a neved és email címed, és értesítünk, ha új eseményt hirdetünk meg."
            buttonLabel="Feliratkozás"
            buttonHref="#feliratkozas"
            dark
          />

          <div class="mt-6 panel-soft p-6 sm:p-8">
            {subscribeSuccess && <p class="mb-4 rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm text-cyan-800">{subscribeSuccess}</p>}
            {subscribeError && <p class="mb-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">{subscribeError}</p>}

            {!subscribeSuccess && (
              <form method="POST" class="flex flex-col gap-4 sm:flex-row">
                <input
                  type="text"
                  name="name"
                  required
                  placeholder="Teljes neved"
                  class="w-full flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100"
                />
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="email@pelda.hu"
                  class="w-full flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-100"
                />
                <button type="submit" class="button-primary">Feliratkozás</button>
              </form>
            )}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
