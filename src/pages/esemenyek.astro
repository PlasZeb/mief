---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// @ts-ignore
import { env } from 'cloudflare:workers';

const db = (env as any)?.mief_db;
let allEvents = [];
let dbError = null;

if (db) {
  try {
    const result = await db.prepare("SELECT * FROM events").all();
    allEvents = result.results || [];
  } catch (e) {
    console.error("Database query error:", e);
    dbError = "Nem sikerült betölteni az eseményeket.";
  }
}

const now = new Date();
const upcomingEvents = allEvents
  .filter(event => new Date(event.date) >= now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = allEvents
  .filter(event => new Date(event.date) < now)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<html lang="hu" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>Eseménytár | MIEF</title>
    <meta
      name="description"
      content="A MIEF szakmai eseményei, műhelymunkái és kerekasztal-beszélgetései a mesterséges intelligencia etikai kérdéseiről."
    />
  </head>

  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased selection:bg-cyan-500/30">
    <Navbar />

    <main class="py-24">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl mb-6">
            Eseménytár
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed">
            A MIEF rendszeres online és személyes alkalmakon dolgozza fel a mesterséges intelligencia etikai, jogi, társadalmi, oktatási és biztonsági kérdéseit. Eseményeink célja nem pusztán az információátadás, hanem a szakmai párbeszéd és a közös gondolkodás.
          </p>
        </div>

        {/* Tervezett Események */}
        <section class="mb-24">
          <div class="flex items-center gap-4 mb-10">
            <h2 class="text-2xl font-bold text-white">Tervezett események</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-cyan-500/50 to-transparent"></div>
          </div>

          <div class="grid gap-8 lg:grid-cols-2">
            {upcomingEvents.length > 0 ? (
              upcomingEvents.map((event) => (
                <div class="group relative rounded-3xl border border-cyan-400/20 bg-cyan-400/5 p-8 transition hover:bg-cyan-400/10 shadow-lg shadow-cyan-500/5">
                  <div class="flex flex-col gap-6">
                    <div class="flex flex-wrap items-start justify-between gap-4">
                      <div>
                        <span class="inline-block text-xs font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-3 py-1 rounded-full mb-3">
                          {new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
                        </span>
                        <h3 class="text-2xl font-bold text-white group-hover:text-cyan-300 transition">{event.title}</h3>
                      </div>
                      {event.join_url && (
                        <a href={event.join_url} target="_blank" class="shrink-0 inline-flex items-center justify-center rounded-xl bg-cyan-400 px-6 py-3 text-sm font-bold text-slate-900 transition hover:bg-cyan-300 hover:scale-105 active:scale-95">
                          Regisztráció / Csatlakozás
                        </a>
                      )}
                    </div>
                    
                    <div class="grid sm:grid-cols-2 gap-4 py-6 border-y border-white/5">
                       <div class="flex items-center gap-3">
                         <span class="text-xl">📍</span>
                         <div>
                           <p class="text-[10px] font-bold text-slate-500 uppercase tracking-tighter">Helyszín / Formátum</p>
                           <p class="text-sm text-slate-300">{event.location_url || 'Online műhelymunka'}</p>
                         </div>
                       </div>
                       <div class="flex items-center gap-3">
                         <span class="text-xl">👤</span>
                         <div>
                           <p class="text-[10px] font-bold text-slate-500 uppercase tracking-tighter">Szakmai vezetés</p>
                           <p class="text-sm text-slate-300">MIEF Szakértői közösség</p>
                         </div>
                       </div>
                    </div>

                    <p class="text-slate-300 leading-relaxed whitespace-pre-wrap">
                      {event.description}
                    </p>
                  </div>
                </div>
              ))
            ) : (
              <div class="col-span-full p-12 rounded-3xl border border-dashed border-white/10 text-center">
                <p class="text-slate-400 italic">Jelenleg nincs új esemény meghirdetve. Iratkozz fel híreinkre, hogy értesülj a következőről!</p>
              </div>
            )}
          </div>
        </section>

        {/* Lezajlott Események */}
        <section>
          <div class="flex items-center gap-4 mb-10">
            <h2 class="text-2xl font-bold text-slate-400">Lezajlott események archívuma</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-slate-500/30 to-transparent"></div>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {pastEvents.length > 0 ? (
              pastEvents.map((event) => (
                <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition flex flex-col h-full opacity-80 hover:opacity-100">
                  <div class="flex-1">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500 bg-slate-800 px-2 py-0.5 rounded mb-3 inline-block">
                      {new Date(event.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                    <h4 class="text-lg font-bold text-white mb-4 line-clamp-2">{event.title}</h4>
                    <p class="text-sm text-slate-400 leading-relaxed line-clamp-4">
                      {event.description}
                    </p>
                  </div>
                  <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between">
                     <span class="text-[10px] font-bold text-slate-500 italic uppercase">Lezajlott</span>
                     <span class="text-[10px] text-slate-600">Összefoglaló feltöltés alatt</span>
                  </div>
                </div>
              ))
            ) : (
              <p class="col-span-full text-slate-500 italic text-center py-12">Nincsenek korábbi események rögzítve.</p>
            )}
          </div>
        </section>

        {dbError && <p class="mt-12 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-center text-red-400">{dbError}</p>}
      </div>
    </main>

    <Footer />
  </body>
</html>
