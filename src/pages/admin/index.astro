---
import '../../styles/global.css';

// @ts-ignore
import { env } from 'cloudflare:workers';

// Admin ellenőrzés
const session = Astro.cookies.get("admin_session")?.value;
if (session !== "true") {
  return Astro.redirect("/admin/login");
}

const db = (env as any).mief_db;

// Esemény mentése (Hozzáadás vagy Szerkesztés)
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get("action");
  
  if (action === "save") {
    const id = data.get("id");
    const title = data.get("title");
    const location_url = data.get("location_url");
    const join_url = data.get("join_url");
    const date = data.get("date");
    const description = data.get("description");

    if (id) {
      await db.prepare("UPDATE events SET title = ?, location_url = ?, join_url = ?, date = ?, description = ? WHERE id = ?")
        .bind(title, location_url, join_url, date, description, id)
        .run();
    } else {
      await db.prepare("INSERT INTO events (title, location_url, join_url, date, description) VALUES (?, ?, ?, ?, ?)")
        .bind(title, location_url, join_url, date, description)
        .run();
    }
  } else if (action === "delete") {
    const id = data.get("id");
    await db.prepare("DELETE FROM events WHERE id = ?").bind(id).run();
  } else if (action === "logout") {
    Astro.cookies.delete("admin_session");
    return Astro.redirect("/admin/login");
  }
}

// Események lekérése
const { results: events } = await db.prepare("SELECT * FROM events ORDER BY date DESC").all();
---

<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eseménykezelő Admin | MIEF</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 p-6 sm:p-12">
    <div class="mx-auto max-w-6xl">
      <header class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-6">
          <div class="h-10 w-10 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-600 shadow-lg shadow-cyan-500/20"></div>
          <nav class="flex gap-6">
            <a href="/admin" class="text-sm font-bold text-cyan-400 border-b-2 border-cyan-400 pb-1">Események</a>
            <a href="/admin/members" class="text-sm font-medium text-slate-400 hover:text-white transition">Tagok</a>
            <a href="/admin/experts" class="text-sm font-medium text-slate-400 hover:text-white transition">Szakértők</a>
          </nav>
        </div>
        
        <form method="POST">
          <button name="action" value="logout" class="text-sm font-medium text-slate-400 hover:text-white transition">Kijelentkezés</button>
        </form>
      </header>

      <div class="grid gap-12 lg:grid-cols-3">
        {/* Szerkesztő Form */}
        <div class="lg:col-span-1">
          <div class="sticky top-24 bg-slate-800 border border-white/10 rounded-3xl p-8 shadow-xl">
            <h2 class="text-xl font-bold text-white mb-6" id="form-title">Új esemény hozzáadása</h2>
            
            <form method="POST" id="event-form" class="space-y-4">
              <input type="hidden" name="action" value="save" />
              <input type="hidden" name="id" id="event-id" />
              
              <div>
                <label for="title" class="block text-sm font-medium text-slate-300 mb-1">Cím</label>
                <input type="text" id="title" name="title" required class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" />
              </div>

              <div>
                <label for="location_url" class="block text-sm font-medium text-slate-300 mb-1">Helyszín megnevezése</label>
                <input type="text" id="location_url" name="location_url" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" placeholder="Pl. Online, Budapest, vagy Teams" />
              </div>

              <div>
                <label for="join_url" class="block text-sm font-medium text-slate-300 mb-1">Csatlakozási link (URL)</label>
                <input type="url" id="join_url" name="join_url" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" placeholder="https://..." />
              </div>

              <div>
                <label for="date" class="block text-sm font-medium text-slate-300 mb-1">Dátum</label>
                <input type="date" id="date" name="date" required class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" />
              </div>

              <div>
                <label for="description" class="block text-sm font-medium text-slate-300 mb-1">Leírás (szabad szöveg)</label>
                <textarea id="description" name="description" rows="4" required class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none"></textarea>
              </div>

              <div class="pt-4 flex gap-3">
                <button type="submit" class="flex-1 rounded-xl bg-cyan-400 py-3 text-sm font-bold text-slate-900 hover:bg-cyan-300 transition">Mentés</button>
                <button type="button" onclick="resetForm()" id="reset-btn" class="hidden flex-1 rounded-xl border border-white/10 py-3 text-sm font-bold text-white hover:bg-white/5 transition">Mégse</button>
              </div>
            </form>
          </div>
        </div>

        {/* Események Listája */}
        <div class="lg:col-span-2">
          <div class="space-y-6">
            {events.length === 0 && (
              <div class="text-center py-20 border-2 border-dashed border-white/5 rounded-3xl">
                <p class="text-slate-500">Nincsenek még események.</p>
              </div>
            )}
            
            {events.map((event: any) => (
              <div class="bg-slate-800 border border-white/10 rounded-3xl p-6 shadow-lg flex flex-col sm:flex-row gap-6 items-start">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-2 py-1 rounded">
                      {event.date}
                    </span>
                    {event.location_url && (
                      <span class="text-xs text-slate-400 truncate max-w-[200px]">{event.location_url}</span>
                    )}
                    {event.join_url && (
                       <span class="text-[10px] bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded border border-blue-500/20 font-bold">LINK</span>
                    )}
                  </div>
                  <h3 class="text-xl font-bold text-white mb-2">{event.title}</h3>
                  <p class="text-sm text-slate-400 line-clamp-2">{event.description}</p>
                </div>
                
                <div class="flex sm:flex-col gap-2 w-full sm:w-auto">
                  <button 
                    type="button"
                    class="edit-btn flex-1 sm:w-24 rounded-lg border border-white/10 py-2 text-xs font-bold text-white hover:bg-white/5 transition"
                    data-id={event.id}
                    data-title={event.title}
                    data-location={event.location_url}
                    data-join={event.join_url}
                    data-date={event.date}
                    data-description={event.description}
                  >
                    Szerkesztés
                  </button>
                  <form method="POST" onsubmit="return confirm('Biztosan törlöd?')" class="flex-1">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={event.id} />
                    <button class="w-full sm:w-24 rounded-lg border border-red-500/20 py-2 text-xs font-bold text-red-400 hover:bg-red-500/10 transition">
                      Törlés
                    </button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('edit-btn')) {
          const btn = e.target;
          document.getElementById('form-title').innerText = 'Esemény szerkesztése';
          document.getElementById('event-id').value = btn.dataset.id;
          document.getElementById('title').value = btn.dataset.title;
          document.getElementById('location_url').value = btn.dataset.location || '';
          document.getElementById('join_url').value = btn.dataset.join || '';
          document.getElementById('date').value = btn.dataset.date;
          document.getElementById('description').value = btn.dataset.description;
          document.getElementById('reset-btn').classList.remove('hidden');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      function resetForm() {
        document.getElementById('form-title').innerText = 'Új esemény hozzáadása';
        document.getElementById('event-id').value = '';
        document.getElementById('event-form').reset();
        document.getElementById('reset-btn').classList.add('hidden');
      }
    </script>
  </body>
</html>
