---
import '../../styles/global.css';

// @ts-ignore
import { env } from 'cloudflare:workers';

const session = Astro.cookies.get("admin_session")?.value;
if (session !== "true") {
  return Astro.redirect("/admin/login");
}

const db = (env as any).mief_db;

if (db) {
  // Migráció: linkedin_url és is_founder oszlopok hozzáadása
  try { await db.prepare("ALTER TABLE experts ADD COLUMN linkedin_url TEXT").run(); } catch (e) {}
  try { await db.prepare("ALTER TABLE experts ADD COLUMN is_founder INTEGER DEFAULT 0").run(); } catch (e) {}
  try { await db.prepare("ALTER TABLE experts ADD COLUMN image_url TEXT").run(); } catch (e) {}
  try { await db.prepare("ALTER TABLE experts ADD COLUMN display_order INTEGER DEFAULT 10").run(); } catch (e) {}
}

let success = Astro.url.searchParams.get('msg') === 'saved' ? 'Sikeresen mentve!' : (Astro.url.searchParams.get('msg') === 'deleted' ? 'Sikeresen törölve.' : '');
let error = Astro.url.searchParams.get('error') === 'save' ? 'Hiba történt a mentés során. Ha képet is feltöltöttél, ellenőrizd az EXPERT_IMAGES KV bindinget.' : '';

const normalizeImageUrl = (url?: string | null) => {
  const trimmed = url?.trim();
  if (!trimmed) return null;
  if (/^(https?:|data:|\/)/i.test(trimmed)) return trimmed;
  return `/${trimmed}`;
};

// Szakértő mentése (Hozzáadás vagy Szerkesztés)
if (Astro.request.method === "POST" && db) {
  const data = await Astro.request.formData();
  const action = data.get("action");
  
  if (action === "save") {
    const id = data.get("id");
    const name = data.get("name");
    const role = data.get("role");
    const linkedin_url = data.get("linkedin_url") || null;
    const is_founder = (data.getAll("is_founder") as string[]).includes("1") ? 1 : 0;
    const display_order = parseInt(data.get("display_order") as string) || 10;
    const imageFile = data.get("image_file") as File;
    
    let image_url = data.get("current_image_url") as string || null;

    try {
      if (imageFile && imageFile.name && imageFile.size > 0) {
        const fileExt = imageFile.name.split('.').pop() || 'jpg';
        const fileKey = crypto.randomUUID() + '.' + fileExt;
        const buffer = await imageFile.arrayBuffer();
        await env.EXPERT_IMAGES.put(fileKey, buffer);
        image_url = `/img/${fileKey}`;
      }

      if (id) {
        await db.prepare("UPDATE experts SET name = ?, role = ?, linkedin_url = ?, is_founder = ?, display_order = ?, image_url = ? WHERE id = ?")
          .bind(name, role, linkedin_url, is_founder, display_order, image_url, id)
          .run();
      } else {
        await db.prepare("INSERT INTO experts (name, role, linkedin_url, is_founder, display_order, image_url) VALUES (?, ?, ?, ?, ?, ?)")
          .bind(name, role, linkedin_url, is_founder, display_order, image_url)
          .run();
      }
      return Astro.redirect("/admin/experts?msg=saved");
    } catch (e) {
      console.error(e);
      return Astro.redirect("/admin/experts?error=save");
    }
  } else if (action === "delete") {
    const id = data.get("id");
    try {
      await db.prepare("DELETE FROM experts WHERE id = ?").bind(id).run();
      return Astro.redirect("/admin/experts?msg=deleted");
    } catch(e) {
      return Astro.redirect("/admin/experts?error=save");
    }
  } else if (action === "logout") {
    Astro.cookies.delete("admin_session");
    return Astro.redirect("/admin/login");
  }
}

// Szakértők lekérése
let experts = [];
if (db) {
  const result = await db.prepare("SELECT * FROM experts ORDER BY is_founder DESC, display_order ASC, created_at ASC").all();
  experts = result.results || [];
}
---

<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Szakértők Kezelése | MIEF Admin</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 p-6 sm:p-12">
    <div class="mx-auto max-w-6xl">
      <header class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-6">
          <div class="h-10 w-10 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-600 shadow-lg shadow-cyan-500/20"></div>
          <nav class="flex gap-6 overflow-x-auto pb-2">
            <a href="/admin" class="text-sm font-medium text-slate-400 hover:text-white transition">Események</a>
            <a href="/admin/programs" class="text-sm font-medium text-slate-400 hover:text-white transition">Programok</a>
            <a href="/admin/members" class="text-sm font-medium text-slate-400 hover:text-white transition">Tagok</a>
            <a href="/admin/experts" class="text-sm font-bold text-cyan-400 border-b-2 border-cyan-400 pb-1">Szakértők</a>
            <a href="/admin/documents" class="text-sm font-medium text-slate-400 hover:text-white transition">Dokumentumok</a>
            <a href="/admin/subscribers" class="text-sm font-medium text-slate-400 hover:text-white transition">Feliratkozók</a>
          </nav>
        </div>
        
        <form method="POST">
          <button name="action" value="logout" class="text-sm font-medium text-slate-400 hover:text-white transition">Kijelentkezés</button>
        </form>
      </header>

      <div class="grid gap-12 lg:grid-cols-3">
        {/* Szerkesztő Form */}
        <div class="lg:col-span-1">
          <div class="sticky top-24 rounded-3xl border border-white/10 bg-slate-800 p-8 shadow-xl">
            <h2 class="mb-6 text-xl font-bold text-white" id="form-title">Új szakértő hozzáadása</h2>

            {success && <p class="mb-4 p-3 rounded-xl bg-emerald-500/10 text-xs text-emerald-400">{success}</p>}
            {error && <p class="mb-4 p-3 rounded-xl bg-red-500/10 text-xs text-red-400">{error}</p>}

            <form method="POST" id="expert-form" class="space-y-4" enctype="multipart/form-data">
              <input type="hidden" name="action" value="save" />
              <input type="hidden" name="id" id="expert-id" />
              <input type="hidden" name="current_image_url" id="current_image_url" />
              
              <div>
                <label for="name" class="block text-sm font-medium text-slate-300 mb-1">Név</label>
                <input type="text" id="name" name="name" required class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" />
              </div>

              <div>
                <label for="role" class="block text-sm font-medium text-slate-300 mb-1">Megnevezés / Titulus</label>
                <textarea id="role" name="role" rows="3" required class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" placeholder="Pl. kibervédelmi szakértő, egyetemi docens"></textarea>
              </div>

              <div>
                <label for="linkedin_url" class="block text-sm font-medium text-slate-300 mb-1">LinkedIn URL</label>
                <input type="url" id="linkedin_url" name="linkedin_url" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-white focus:border-cyan-400 focus:outline-none" placeholder="https://linkedin.com/in/..." />
              </div>

              <div>
                <label for="image_file" class="block text-sm font-medium text-slate-300 mb-1">Profilkép feltöltése</label>
                <input type="file" id="image_file" name="image_file" accept="image/*" class="w-full text-sm text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-cyan-500/20 file:text-cyan-400 hover:file:bg-cyan-500/30" />
                <p class="mt-1 text-[10px] italic text-slate-500">Válassz egy képet a gépedről. A fájl az <code>EXPERT_IMAGES</code> KV-be kerül, és <code>/img/...</code> útvonalon jelenik meg. Ha nem választasz újat, a régi megmarad.</p>
              </div>

              <div class="flex items-center gap-3 pt-2">
                <input type="checkbox" id="is_founder" name="is_founder" value="1" class="w-5 h-5 rounded accent-cyan-400 cursor-pointer" />
                <label for="is_founder" class="text-sm font-medium text-cyan-300 cursor-pointer">Alapító (kiemelt kártya a weboldalon)</label>
              </div>

              <div>
                <label for="display_order" class="block text-sm font-medium text-slate-300 mb-1">Megjelenési sorrend</label>
                <div class="flex items-center gap-4">
                  <input type="range" id="display_order_slider" min="1" max="50" value="10" class="flex-1 accent-cyan-400 cursor-pointer" oninput="document.getElementById('display_order').value = this.value" />
                  <input type="number" id="display_order" name="display_order" min="1" max="50" value="10" required class="w-20 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-center text-white focus:border-cyan-400 focus:outline-none" oninput="document.getElementById('display_order_slider').value = this.value" />
                </div>
                <p class="text-[10px] text-slate-500 mt-1 italic">Kisebb szám = előrébb jelenik meg a listában. (Alapítók mindig legelöl vannak)</p>
              </div>

              <div class="pt-4 flex gap-3">
                <button type="submit" class="flex-1 rounded-xl bg-cyan-400 py-3 text-sm font-bold text-slate-900 hover:bg-cyan-300 transition">Mentés</button>
                <button type="button" onclick="resetForm()" id="reset-btn" class="hidden flex-1 rounded-xl border border-white/10 py-3 text-sm font-bold text-white hover:bg-white/5 transition">Mégse</button>
              </div>
            </form>
          </div>
        </div>

        {/* Szakértők Listája */}
        <div class="lg:col-span-2">
          <div class="space-y-6">
            {experts.length === 0 && (
              <div class="text-center py-20 border-2 border-dashed border-white/5 rounded-3xl">
                <p class="text-slate-500">Nincsenek még szakértők rögzítve.</p>
              </div>
            )}
            
            {experts.map((expert: any) => (
              <div class={`border rounded-3xl p-6 shadow-lg flex flex-col sm:flex-row gap-6 items-start ${expert.is_founder ? 'bg-cyan-400/5 border-cyan-400/30' : 'bg-slate-800 border-white/10'}`}>
                {normalizeImageUrl(expert.image_url) ? (
                  <img src={normalizeImageUrl(expert.image_url)!} alt={expert.name} class="w-20 h-20 rounded-2xl object-cover border border-white/10 shrink-0" />
                ) : (
                  <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                    <svg class="w-8 h-8 text-slate-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                  </div>
                )}
                
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2 flex-wrap">
                    <h3 class="text-xl font-bold text-white">{expert.name}</h3>
                    {expert.is_founder ? <span class="text-[10px] bg-cyan-400/20 text-cyan-300 px-2 py-0.5 rounded-full border border-cyan-400/30 font-bold uppercase tracking-wider">★ Alapító</span> : null}
                    <span class="text-[10px] bg-slate-500/20 text-slate-400 px-2 py-0.5 rounded-full border border-slate-500/30 font-bold uppercase tracking-wider">Sorrend: {expert.display_order || 10}</span>
                  </div>
                  <p class="text-sm text-slate-400">{expert.role}</p>
                  {expert.linkedin_url && <a href={expert.linkedin_url} target="_blank" class="mt-1 text-xs text-cyan-400 hover:underline">LinkedIn</a>}
                </div>
                
                <div class="flex sm:flex-col gap-2 w-full sm:w-auto shrink-0">
                  <button 
                    type="button"
                    class="edit-btn flex-1 sm:w-24 rounded-lg border border-white/10 py-2 text-xs font-bold text-white hover:bg-white/5 transition"
                    data-id={expert.id}
                    data-name={expert.name}
                    data-role={expert.role}
                    data-linkedin={expert.linkedin_url || ''}
                    data-founder={expert.is_founder ? '1' : '0'}
                    data-displayorder={expert.display_order || '10'}
                    data-image={expert.image_url || ''}
                  >
                    Szerkesztés
                  </button>
                  <form method="POST" onsubmit="return confirm('Biztosan törlöd a szakértőt?')" class="flex-1">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={expert.id} />
                    <button class="w-full sm:w-24 rounded-lg border border-red-500/20 py-2 text-xs font-bold text-red-400 hover:bg-red-500/10 transition">
                      Törlés
                    </button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('edit-btn')) {
          const btn = e.target;
          document.getElementById('form-title').innerText = 'Szakértő szerkesztése';
          document.getElementById('expert-id').value = btn.dataset.id;
          document.getElementById('name').value = btn.dataset.name;
          document.getElementById('role').value = btn.dataset.role;
          document.getElementById('linkedin_url').value = btn.dataset.linkedin || '';
          document.getElementById('current_image_url').value = btn.dataset.image || '';
          
          document.getElementById('is_founder').checked = btn.dataset.founder === '1';
          document.getElementById('display_order').value = btn.dataset.displayorder;
          document.getElementById('display_order_slider').value = btn.dataset.displayorder;
          
          document.getElementById('reset-btn').classList.remove('hidden');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      function resetForm() {
        document.getElementById('form-title').innerText = 'Új szakértő hozzáadása';
        document.getElementById('expert-id').value = '';
        document.getElementById('current_image_url').value = '';
        document.getElementById('expert-form').reset();
        document.getElementById('display_order').value = '10';
        document.getElementById('display_order_slider').value = '10';
        document.getElementById('reset-btn').classList.add('hidden');
      }
    </script>
  </body>
</html>
