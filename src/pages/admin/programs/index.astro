---
import '../../../styles/global.css';

// @ts-ignore
import { env } from 'cloudflare:workers';

const session = Astro.cookies.get("programs_session");
if (!session || session.value !== "true") {
  return Astro.redirect("/admin/programs/login");
}

const db = (env as any).mief_db;
type ProgramRow = { id: number; title: string; url?: string; location?: string; date: string; notes?: string; created_by?: string; is_featured?: number; created_at?: string; };
let programs: ProgramRow[] = [];
let error = "";
let success = "";
const today = new Date().toISOString().split('T')[0];

// Migráció: created_by oszlop hozzáadása (ha még nincs)
try {
  await db.prepare("ALTER TABLE programs ADD COLUMN created_by TEXT").run();
} catch (e) { /* Már létezik */ }

// Migráció: is_featured oszlop hozzáadása (ha még nincs)
try {
  await db.prepare("ALTER TABLE programs ADD COLUMN is_featured INTEGER DEFAULT 0").run();
} catch (e) { /* Már létezik */ }

// Új program felvétele
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get("action");

  if (action === "add") {
    const title = data.get("title");
    const url = data.get("url");
    const location = data.get("location");
    const date = data.get("date");
    const notes = data.get("notes");
    const created_by = data.get("created_by");
    const is_featured = data.get("is_featured") === "1" ? 1 : 0;

    if (title && date) {
      try {
        await db.prepare("INSERT INTO programs (title, url, location, date, notes, created_by, is_featured) VALUES (?, ?, ?, ?, ?, ?, ?)")
          .bind(title, url, location, date, notes, created_by, is_featured)
          .run();
        success = "Program sikeresen hozzáadva!";
      } catch (e) {
        error = "Hiba történt a mentés során.";
      }
    } else {
      error = "A név és az időpont megadása kötelező!";
    }
  }

  // Szerkesztés (Edit)
  if (action === "edit") {
    const id = data.get("id");
    const title = data.get("title");
    const url = data.get("url");
    const location = data.get("location");
    const date = data.get("date");
    const notes = data.get("notes");
    const created_by = data.get("created_by");
    const is_featured = data.get("is_featured") === "1" ? 1 : 0;

    if (id && title && date) {
      try {
        await db.prepare("UPDATE programs SET title = ?, url = ?, location = ?, date = ?, notes = ?, created_by = ?, is_featured = ? WHERE id = ?")
          .bind(title, url, location, date, notes, created_by, is_featured, id)
          .run();
        success = "Program sikeresen módosítva!";
      } catch (e) {
        error = "Hiba történt a módosítás során.";
      }
    } else {
      error = "A név és az időpont megadása kötelező a módosításhoz is!";
    }
  }

  // Törlés
  if (action === "delete") {
    const id = data.get("id");
    try {
      await db.prepare("DELETE FROM programs WHERE id = ?").bind(id).run();
      success = "Program törölve!";
    } catch (e) {
      error = "Hiba történt a törlés során.";
    }
  }
}

// Programok listázása
try {
  const result = await db.prepare("SELECT * FROM programs ORDER BY date ASC").all();
  programs = result.results || [];
} catch (e) {
  error = "Nem sikerült betölteni a programokat.";
}
---

<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Programajánló Kezelő | MIEF Admin</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 p-6">
    <div class="max-w-4xl mx-auto">
      <header class="flex justify-between items-center mb-12">
        <div>
          <h1 class="text-3xl font-bold text-white">Programajánló Kezelő</h1>
          <p class="text-slate-400 mt-2">Külsős események és konferenciák kezelése</p>
        </div>
        <a href="/" class="text-sm text-slate-400 hover:text-white transition">Vissza a főoldalra</a>
      </header>

      {/* Új program hozzáadása */}
      <section class="bg-slate-800 border border-white/10 rounded-3xl p-8 mb-12 shadow-xl">
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Új program hozzáadva
        </h2>

        {error && <p class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm">{error}</p>}
        {success && <p class="mb-6 p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl text-sm">{success}</p>}

        <form method="POST" class="grid gap-6 md:grid-cols-2">
          <input type="hidden" name="action" value="add" />
          
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-400 mb-2">Esemény címe / Elnevezése *</label>
            <input name="title" required class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" placeholder="Pl: AI Safety Conference 2026" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Helyszín</label>
            <input name="location" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" placeholder="Pl: Budapest, Corvinus" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Időpont *</label>
            <input name="date" type="date" required class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Weboldal / Link</label>
            <input name="url" type="url" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" placeholder="https://..." />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Megjegyzés</label>
            <input name="notes" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" placeholder="Rövid leírás vagy infó" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2 text-emerald-400">Felvivő neve (Admin belső) *</label>
            <input name="created_by" required class="w-full bg-slate-900 border border-emerald-400/20 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" placeholder="Ki rögzíti az eseményt?" />
            <p class="text-[10px] text-slate-500 mt-1 italic">Ez a mező és a tartalma csak az admin felületen látható.</p>
          </div>
          <div class="md:col-span-2 flex items-center gap-3">
            <input type="hidden" name="is_featured" value="0" />
            <input type="checkbox" id="is_featured_add" name="is_featured" value="1" class="w-5 h-5 rounded accent-emerald-400 cursor-pointer" />
            <label for="is_featured_add" class="text-sm font-medium text-emerald-300 cursor-pointer">Kiemelt program (nagyobb kártya, „Kiemelt” badge a főoldalon)</label>
          </div>
          <div class="md:col-span-2">
            <button type="submit" class="w-full bg-emerald-400 hover:bg-emerald-300 text-slate-900 font-bold py-4 rounded-xl transition shadow-lg shadow-emerald-500/20">
              Program mentése
            </button>
          </div>
        </form>
      </section>

      {/* Meglévő programok */}
      <section>
        <h2 class="text-xl font-bold text-white mb-6">Jelenlegi ajánlott programok</h2>
        <div class="space-y-4">
          {programs.length === 0 && <p class="text-slate-500 italic text-center py-12">Nincsenek még rögzített programok.</p>}
          {programs.map((p) => {
            const isExpired = p.date < today;
            return (
              <>
              <div class={`border rounded-2xl p-6 flex justify-between items-center group transition ${isExpired ? 'bg-red-500/10 border-red-500/30 hover:border-red-500/50' : 'bg-slate-800/50 border-white/5 hover:border-emerald-400/30'}`}>
                <div>
                  <div class="flex items-center gap-3">
                    <h3 class="font-bold text-white text-lg">{p.title}</h3>
                    {p.created_by && <span class="text-[10px] bg-emerald-500/10 text-emerald-400 px-2 py-0.5 rounded-full border border-emerald-500/20">👤 {p.created_by}</span>}
                    {p.is_featured ? <span class="text-[10px] bg-emerald-400/20 text-emerald-300 px-2 py-0.5 rounded-full border border-emerald-400/30 font-bold uppercase tracking-wider">★ Kiemelt</span> : null}
                    {isExpired && <span class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full border border-red-500/20 font-bold uppercase tracking-wider">Lejárt</span>}
                  </div>
                  <div class="flex flex-wrap gap-4 mt-2 text-sm text-slate-400">
                    <span class={`flex items-center gap-1 ${isExpired ? 'text-red-400 font-bold' : ''}`}>📅 {p.date}</span>
                    {p.location && <span class="flex items-center gap-1">📍 {p.location}</span>}
                    {p.url && <a href={p.url} target="_blank" class="text-emerald-400 hover:underline">Link</a>}
                  </div>
                  {p.notes && <p class="mt-2 text-sm text-slate-500">{p.notes}</p>}
                  <p class="mt-1 text-[10px] text-slate-600">Rögzítve: {p.created_at}</p>
                </div>
                
                <div class="flex gap-2">
                  <button type="button" class="p-2 text-slate-500 hover:text-emerald-400 transition" onclick={`document.getElementById('edit-form-${p.id}').classList.toggle('hidden')`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </button>
                  <form method="POST">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={p.id} />
                    <button type="submit" class="p-2 text-slate-500 hover:text-red-400 transition" onclick="return confirm('Biztosan törlöd?')">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </form>
                </div>
              </div>
              
              {/* Szerkesztő form (alapértelmezetten rejtett) */}
              <form method="POST" id={`edit-form-${p.id}`} class="hidden mt-6 pt-6 border-t border-white/10 grid gap-4 md:grid-cols-2">
                <input type="hidden" name="action" value="edit" />
                <input type="hidden" name="id" value={p.id} />
                
                <div class="md:col-span-2">
                  <label class="block text-xs font-medium text-slate-400 mb-1">Esemény címe</label>
                  <input name="title" value={p.title} required class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-slate-400 mb-1">Helyszín</label>
                  <input name="location" value={p.location} class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-slate-400 mb-1">Időpont</label>
                  <input name="date" type="date" value={p.date} required class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-slate-400 mb-1">Link</label>
                  <input name="url" type="url" value={p.url} class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-slate-400 mb-1 text-emerald-400">Felvivő neve</label>
                  <input name="created_by" value={p.created_by} required class="w-full bg-slate-900/50 border border-emerald-400/20 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-slate-400 mb-1">Megjegyzés</label>
                  <input name="notes" value={p.notes} class="w-full bg-slate-900/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:border-emerald-400 outline-none" />
                </div>
                <div class="md:col-span-2 flex items-center gap-3">
                  <input type="hidden" name="is_featured" value="0" />
                  <input type="checkbox" id={`is_featured_${p.id}`} name="is_featured" value="1" checked={p.is_featured ? true : false} class="w-5 h-5 rounded accent-emerald-400 cursor-pointer" />
                  <label for={`is_featured_${p.id}`} class="text-sm font-medium text-emerald-300 cursor-pointer">Kiemelt program</label>
                </div>
                <div class="md:col-span-2 flex justify-end gap-2 mt-2">
                  <button type="button" onclick={`document.getElementById('edit-form-${p.id}').classList.add('hidden')`} class="px-4 py-2 rounded-lg text-sm text-slate-400 hover:text-white transition">Mégse</button>
                  <button type="submit" class="bg-emerald-400/20 text-emerald-400 hover:bg-emerald-400 hover:text-slate-900 px-4 py-2 rounded-lg text-sm font-bold transition">Mentés</button>
                </div>
              </form>
              </>
            );
          })}
        </div>
      </section>
    </div>
  </body>
</html>
