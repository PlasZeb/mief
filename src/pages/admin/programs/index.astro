---
import '../../../styles/global.css';

// @ts-ignore
import { env } from 'cloudflare:workers';

const session = Astro.cookies.get("programs_session")?.value;
if (session !== "true") {
  return Astro.redirect("/admin/programs/login");
}

const db = (env as any).mief_db;

// Migrációk
try { await db.prepare("ALTER TABLE programs ADD COLUMN created_by TEXT").run(); } catch (e) {}
try { await db.prepare("ALTER TABLE programs ADD COLUMN is_featured INTEGER DEFAULT 0").run(); } catch (e) {}
try { await db.prepare("ALTER TABLE programs ADD COLUMN speaker TEXT").run(); } catch (e) {}

let success = "";
let error = "";
const today = new Date().toISOString().split('T')[0];

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get("action");

  if (action === "add" || action === "edit") {
    const id = data.get("id");
    const title = data.get("title");
    const url = data.get("url");
    const location = data.get("location");
    const date = data.get("date");
    const notes = data.get("notes");
    const speaker = data.get("speaker");
    const created_by = data.get("created_by");
    const is_featured = (data.getAll("is_featured") as string[]).includes("1") ? 1 : 0;

    if (title && date) {
      try {
        if (action === "add") {
          await db.prepare("INSERT INTO programs (title, url, location, date, notes, speaker, created_by, is_featured) VALUES (?, ?, ?, ?, ?, ?, ?, ?)")
            .bind(title, url, location, date, notes, speaker, created_by, is_featured)
            .run();
          success = "Program hozzáadva!";
          
          // Email küldés jóváhagyott feliratkozóknak
          const resendApiKey = (env as any).RESEND_API_KEY;
          if (resendApiKey && resendApiKey !== "ide_illeszd_be_az_api_kulcsot") {
            try {
              const { results: subs } = await db.prepare("SELECT email FROM subscribers WHERE status = 'approved'").all();
              if (subs && subs.length > 0) {
                const fDate = new Date(date as string).toLocaleDateString("hu-HU", { year: "numeric", month: "long", day: "numeric" });
                await fetch("https://api.resend.com/emails", {
                  method: "POST",
                  headers: { "Authorization": `Bearer ${resendApiKey}`, "Content-Type": "application/json" },
                  body: JSON.stringify({
                    from: "MIEF <noreply@mief.hu>",
                    to: (subs as any[]).map((s: any) => s.email),
                    subject: `Új program: ${title}`,
                    html: `<div style="font-family:sans-serif;max-width:600px;margin:0 auto;color:#1e293b;"><h2 style="color:#0891b2;">Új program a MIEF ajánlójában</h2><h3>${title}</h3><p><strong>Időpont:</strong> ${fDate}</p>${location ? `<p><strong>Helyszín:</strong> ${location}</p>` : ""}${notes ? `<p>${notes}</p>` : ""}${url ? `<p><a href="${url}" style="background:#0891b2;color:#fff;padding:10px 20px;border-radius:6px;text-decoration:none;">Részletek megtekintése</a></p>` : ""}</div>`
                  })
                });
                success = "Program és értesítő elküldve!";
              }
            } catch (ee) {}
          }
        } else {
          await db.prepare("UPDATE programs SET title = ?, url = ?, location = ?, date = ?, notes = ?, speaker = ?, created_by = ?, is_featured = ? WHERE id = ?")
            .bind(title, url, location, date, notes, speaker, created_by, is_featured, id)
            .run();
          success = "Módosítva!";
        }
      } catch (e) { error = "Hiba történt!"; }
    }
  }

  if (action === "delete") {
    const id = data.get("id");
    await db.prepare("DELETE FROM programs WHERE id = ?").bind(id).run();
    success = "Törölve.";
  }
  
  if (action === "logout") {
    Astro.cookies.delete("programs_session");
    return Astro.redirect("/admin/programs/login");
  }
}

const { results: programs } = await db.prepare("SELECT * FROM programs ORDER BY date ASC").all();
---

<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Programok | MIEF Admin</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 p-6 sm:p-12">
    <div class="mx-auto max-w-5xl">
      <header class="flex items-center justify-between mb-12">
        <div>
          <h1 class="text-3xl font-bold text-white">Programok kezelése</h1>
          <p class="text-slate-400 mt-1">Külsős események és konferenciák</p>
        </div>
        <div class="flex gap-4 items-center">
          <a href="/" class="text-sm text-slate-400 hover:text-white transition">Főoldal</a>
          <form method="POST">
            <button name="action" value="logout" class="text-sm font-medium text-red-400 hover:text-red-300 transition">Kijelentkezés</button>
          </form>
        </div>
      </header>

      <section class="bg-slate-800 border border-white/10 rounded-3xl p-8 mb-12 shadow-xl">
        <h2 class="text-xl font-bold text-white mb-6" id="form-title">Új program hozzáadása</h2>
        {success && <p class="mb-6 p-4 bg-emerald-500/10 text-emerald-400 rounded-xl text-sm border border-emerald-500/20 font-medium">{success}</p>}
        {error && <p class="mb-6 p-4 bg-red-500/10 text-red-400 rounded-xl text-sm border border-red-500/20 font-medium">{error}</p>}
        
        <form method="POST" id="program-form" class="grid gap-6 md:grid-cols-2">
          <input type="hidden" name="action" id="form-action" value="add" />
          <input type="hidden" name="id" id="program-id" />
          
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-400 mb-2">Esemény címe *</label>
            <input name="title" id="title" required class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Dátum *</label>
            <input name="date" id="date" type="date" required class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2 text-emerald-400">Felvivő neve *</label>
            <input name="created_by" id="created_by" required class="w-full bg-slate-900 border border-emerald-400/20 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Helyszín</label>
            <input name="location" id="location" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Weboldal / Link</label>
            <input name="url" id="url" type="url" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Előadó(k)</label>
            <input name="speaker" id="speaker" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none" />
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" id="is_featured" name="is_featured" value="1" class="w-5 h-5 rounded accent-emerald-400 cursor-pointer" />
            <label for="is_featured" class="text-sm font-medium text-emerald-300 cursor-pointer">Kiemelt program</label>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-400 mb-2">Megjegyzés (rövid leírás)</label>
            <textarea name="notes" id="notes" rows="3" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-emerald-400 outline-none"></textarea>
          </div>
          <div class="md:col-span-2 flex gap-3">
            <button type="submit" class="flex-1 bg-emerald-400 hover:bg-emerald-300 text-slate-900 font-bold py-4 rounded-xl transition shadow-lg shadow-emerald-500/20">Program mentése</button>
            <button type="button" onclick="resetForm()" id="reset-btn" class="hidden flex-1 border border-white/10 hover:bg-white/5 text-white font-bold py-4 rounded-xl transition">Mégse</button>
          </div>
        </form>
      </section>

      <div class="space-y-4">
        <h2 class="text-xl font-bold text-white mb-6">Rögzített programok</h2>
        {programs.length === 0 && <p class="text-slate-500 italic py-8 text-center border-2 border-dashed border-white/5 rounded-3xl">Még nincsenek programok.</p>}
        {(programs as any[]).map((p) => {
          const isExpired = p.date < today;
          return (
            <div class={`border rounded-2xl p-6 flex flex-col sm:flex-row justify-between items-center gap-6 group transition ${isExpired ? 'bg-red-500/5 border-red-500/20' : 'bg-slate-800/50 border-white/5 hover:border-emerald-400/30'}`}>
              <div class="flex-1 w-full">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="font-bold text-white text-lg">{p.title}</h3>
                  {p.is_featured ? <span class="text-[10px] bg-emerald-400/20 text-emerald-300 px-2 py-0.5 rounded-full border border-emerald-400/30 font-bold">★ KIEMELT</span> : null}
                  {isExpired && <span class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full border border-red-500/20 font-bold uppercase">Lejárt</span>}
                </div>
                <div class="flex flex-wrap gap-4 mt-2 text-sm text-slate-400">
                  <span>📅 {p.date}</span>
                  {p.location && <span>📍 {p.location}</span>}
                  {p.created_by && <span class="opacity-60 text-xs">👤 {p.created_by}</span>}
                </div>
              </div>
              <div class="flex gap-2 w-full sm:w-auto">
                <button 
                  type="button" 
                  class="edit-btn flex-1 sm:w-24 bg-white/5 hover:bg-white/10 text-white text-xs font-bold py-2 rounded-lg border border-white/10 transition"
                  data-id={p.id}
                  data-title={p.title}
                  data-date={p.date}
                  data-location={p.location || ''}
                  data-url={p.url || ''}
                  data-notes={p.notes || ''}
                  data-speaker={p.speaker || ''}
                  data-created_by={p.created_by || ''}
                  data-featured={p.is_featured}
                >Szerkesztés</button>
                <form method="POST" class="flex-1">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={p.id} />
                  <button type="submit" class="w-full sm:w-24 border border-red-500/20 text-red-400 hover:bg-red-500/10 text-xs font-bold py-2 rounded-lg transition" onclick="return confirm('Törlöd?')">Törlés</button>
                </form>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <script is:inline>
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('edit-btn')) {
          const b = e.target.dataset;
          document.getElementById('form-title').innerText = 'Program szerkesztése';
          document.getElementById('form-action').value = 'edit';
          document.getElementById('program-id').value = b.id;
          document.getElementById('title').value = b.title;
          document.getElementById('date').value = b.date;
          document.getElementById('location').value = b.location;
          document.getElementById('url').value = b.url;
          document.getElementById('notes').value = b.notes;
          document.getElementById('speaker').value = b.speaker;
          document.getElementById('created_by').value = b.created_by;
          document.getElementById('is_featured').checked = b.featured === '1';
          document.getElementById('reset-btn').classList.remove('hidden');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      function resetForm() {
        document.getElementById('form-title').innerText = 'Új program hozzáadása';
        document.getElementById('form-action').value = 'add';
        document.getElementById('program-id').value = '';
        document.getElementById('program-form').reset();
        document.getElementById('reset-btn').classList.add('hidden');
      }
    </script>
  </body>
</html>
